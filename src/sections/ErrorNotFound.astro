---

---

<section
    class="error-not-found"
    aria-labelledby="error-not-found-title"
>
    <div
        class="error-not-found__inner shell"
        data-scroll
    >
        <p class="error-not-found__code" aria-hidden="true">404</p>
        <h1 id="error-not-found-title" class="error-not-found__title" data-i18n="This page doesn't exist">This page doesn't exist</h1>
        <p class="error-not-found__text" data-i18n="The link may be outdated or the page may have moved.">The link may be outdated or the page may have moved.</p>
        <div class="error-not-found__actions flex justify-center">
            <a
                class="button"
                href="/"
            >
                <span data-i18n="Go home">Go home</span>
            </a>
        </div>
    </div>
</section>

<style>
    .error-not-found {
        align-items: center;
        display: flex;
        justify-content: center;
        min-height: calc(100vh - var(--header-height));
        padding-bottom: clamp(48px, calc(30.67px + 5.42vw), 100px);
        padding-top: calc(var(--header-height) + clamp(48px, calc(30.67px + 5.42vw), 100px));
    }

    .error-not-found__code {
        color: color-mix(in srgb, var(--color-cobalt) 18%, var(--color-white));
        font-family: var(--font-heading);
        font-size: clamp(120px, calc(80px + 12.5vw), 240px);
        font-weight: 700;
        letter-spacing: -0.05em;
        line-height: 0.8;
        margin: 0 0 clamp(24px, calc(18.67px + 1.67vw), 40px);
        user-select: none;
    }

    .error-not-found__inner {
        max-width: 620px;
        text-align: center;
    }

    .error-not-found__text {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0 0 32px;
    }

    .error-not-found__title {
        font-size: clamp(24px, calc(18.67px + 1.67vw), 40px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
    }
</style>
