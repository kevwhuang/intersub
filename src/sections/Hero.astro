---
import { Image } from 'astro:assets';

import hero from '@images/hero.webp';
---

<section
    class="hero grid isolate overflow-hidden relative"
    aria-label="InterSub, a business English communication studio."
    data-i18n-aria="InterSub, a business English communication studio."
>
    <div class="hero__background absolute" aria-hidden="true">
        <Image
            class="hero__background-image"
            alt=""
            priority
            sizes="100vw"
            src={hero}
            widths={[768, 1280, 1920]}
        />
    </div>
    <div class="hero__overlay absolute" aria-hidden="true" />
    <div class="hero__content shell relative">
        <h1 class="hero__title" data-scroll>
            <span class="hero__title-line"><span data-i18n="Your">Your</span> <span class="hero__accent" data-i18n="authority">authority</span></span>
            <span class="hero__title-line"><span data-i18n="in">in</span> <span class="hero__accent" data-i18n="English">English</span></span>
        </h1>
        <p class="hero__subtitle" data-i18n-html="hero-subtitle" data-scroll>Private coaching, team workshops, and focused events for Chinese professionals who lead meetings, close deals, and write under pressure.</p>
    </div>
</section>

<style>
    .hero {
        align-items: center;
        background: var(--color-navy);
        min-height: 100vh;
    }

    .hero__accent {
        color: var(--color-cobalt-bright);
    }

    .hero__background {
        inset: 0;
        z-index: -2;
    }

    .hero__background-image {
        height: 100%;
        object-fit: cover;
        object-position: 65% 42%;
        width: 100%;
    }

    .hero__content {
        padding-bottom: clamp(56px, 10vh, 104px);
        padding-top: clamp(116px, 16vh, 176px);
    }

    .hero__overlay {
        background:
            linear-gradient(to right, var(--color-midnight-70) 0%, var(--color-midnight-40) 70%, var(--color-midnight-30) 100%),
            var(--color-midnight-20);
        inset: 0;
        z-index: -1;
    }

    .hero__subtitle {
        color: var(--color-white-90);
        font-size: clamp(16px, 1.5vw, 20px);
        line-height: 1.6;
        margin: 0;
        max-width: 640px;
        text-shadow: 0 1px 24px var(--color-black-50);
        text-wrap: pretty;
    }

    .hero__title {
        color: var(--color-white);
        font-size: clamp(36px, 6vw, 72px);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.03;
        margin: 0 0 28px;
        text-shadow: 0 2px 34px var(--color-black-50);
    }

    .hero__title-line {
        display: block;
    }
</style>
