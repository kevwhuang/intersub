---
import { Image } from 'astro:assets';

import hero from '@images/hero.jpg';
---

<section
    class="hero grid isolate relative overflow-hidden"
    aria-label="InterSub, a business English communication studio. A laptop on a sunlit office windowsill shows a presentation titled The Power of Intersubjectivity in Business, framed by the Shanghai skyline beyond the glass."
>
    <div class="hero__background absolute" aria-hidden="true">
        <Image
            class="hero__background-image"
            alt=""
            loading="eager"
            sizes="100vw"
            src={hero}
            widths={[768, 1280, 1920]}
        />
    </div>
    <div class="hero__overlay absolute" aria-hidden="true" />
    <div class="hero__content shell relative">
        <h1 class="hero__title" data-scroll><span data-i18n="Your">Your</span> <span class="hero__accent" data-i18n="authority">authority</span><span data-i18n=",">,</span> <span data-i18n="in">in</span> <span class="hero__accent" data-i18n="English">English</span><span data-i18n=".">.</span></h1>
        <p class="hero__subtitle" data-i18n-html="hero-subtitle" data-scroll>Private coaching, team workshops, and focused seminars for Chinese professionals who lead meetings, close deals, and write under pressure. In English.</p>
    </div>
</section>

<style>
    .hero {
        align-items: center;
        background: var(--color-dark-deep);
        min-height: 100vh;
    }

    .hero__background {
        inset: 0;
        z-index: -2;
    }

    .hero__background-image {
        height: 100%;
        object-fit: cover;
        object-position: 65% 42%;
        width: 100%;
    }

    .hero__content {
        padding-bottom: clamp(56px, 10vh, 104px);
        padding-top: clamp(116px, 16vh, 176px);
    }

    .hero__overlay {
        background:
            linear-gradient(to right, #090b11b8 0%, #090b1161 70%, #090b1147 100%),
            #090b1138;
        inset: 0;
        z-index: -1;
    }

    .hero__accent {
        color: var(--color-accent-bright);
    }

    .hero__subtitle {
        color: #ffffffe6;
        font-size: clamp(17px, 1.5vw, 21px);
        line-height: 1.6;
        margin: 0;
        max-width: 640px;
        text-shadow: 0 1px 24px #00000080;
        text-wrap: pretty;
    }

    .hero__title {
        color: var(--color-surface);
        font-size: clamp(36px, 6vw, 72px);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.03;
        margin: 0 0 28px;
        max-width: 560px;
        text-shadow: 0 2px 34px #00000080;
        text-wrap: balance;
    }
</style>
