---
import { Image } from 'astro:assets';

import qrCode from '@images/qr.png';
import { ROUTES, SOCIALS } from '@lib/utils';
---

<footer
    class="site-footer"
    aria-label="Site footer"
>
    <div class="shell site-footer__inner grid items-start">
        <div>
            <h2 class="site-footer__wordmark">InterSub</h2>
            <p class="site-footer__tag" data-i18n="Business English coaching, workshops, and seminars for Chinese professionals who lead meetings, close deals, and write under pressure. We practise on your real work and give feedback you use the same day. Based in Shanghai.">Business English coaching, workshops, and seminars for Chinese professionals who lead meetings, close deals, and write under pressure. We practise on your real work and give feedback you use the same day. Based in Shanghai.</p>
        </div>
        <div class="site-footer__column">
            <p class="site-footer__heading" data-i18n="Directory">Directory</p>
            <div class="flex flex-col gap-3">
                {ROUTES.map(route => (
                    <a
                        class="site-footer__link"
                        href={route.href}
                    >
                        <span data-i18n={route.label}>{route.label}</span>
                    </a>
                ))}
                {import.meta.env.DEV && (
                    <a
                        class="site-footer__link"
                        href="/admin"
                    >
                        <span data-i18n="Admin">Admin</span>
                    </a>
                )}
            </div>
        </div>
        <div class="site-footer__column site-footer__connect">
            <div class="site-footer__qr-code">
                <p class="site-footer__heading" data-i18n="Weixin">Weixin</p>
                <Image
                    class="site-footer__qr-code-image"
                    alt="Weixin QR code"
                    height={80}
                    src={qrCode}
                    width={80}
                />
            </div>
            <div>
                <p class="site-footer__heading" data-i18n="Follow">Follow</p>
                <div class="site-footer__socials flex flex-wrap">
                    {SOCIALS.map(soc => (
                        <a
                            class="site-footer__social flex items-center justify-center"
                            aria-label={soc.label}
                            href={soc.href}
                            rel="noopener noreferrer"
                            target="_blank"
                            title={soc.label}
                        >
                            {soc.mark}
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </div>
    <div class="shell site-footer__bottom select-none">
        <span data-i18n-html="footer-copyright">&copy; 2026 InterSub. All rights reserved.</span>
        <span data-i18n="Founded by Lydia Zhu">Founded by Lydia Zhu</span>
    </div>
</footer>

<style>
    .site-footer {
        background: var(--color-dark);
        color: var(--color-ink-pale);
    }

    .site-footer__bottom {
        align-items: center;
        border-top: 1px solid var(--color-dark-edge);
        color: var(--color-dark-muted);
        display: flex;
        font-size: 13.5px;
        gap: 8px 24px;
        justify-content: space-between;
        padding-block: 28px;
    }

    .site-footer__column {
        display: flex;
        flex-direction: column;
    }

    .site-footer__heading {
        color: var(--color-dark-muted);
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.1em;
        margin: 0 0 16px;
        text-transform: uppercase;
    }

    .site-footer__inner {
        gap: 40px;
        grid-template-columns: 1.6fr 1fr 1.2fr;
        padding-bottom: 40px;
        padding-top: clamp(48px, 6vw, 72px);
    }

    .site-footer__connect {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .site-footer__link {
        color: var(--color-dark-text);
        font-size: 15px;
        text-decoration: none;
        transition: color var(--duration-fast) ease, opacity var(--duration-fast) ease;
    }

    .site-footer__link:active {
        opacity: 0.7;
    }

    .site-footer__link:focus-visible {
        box-shadow: 0 0 0 3px var(--color-accent-20);
        outline: none;
    }

    .site-footer__link:hover {
        color: var(--color-surface);
    }

    .site-footer__qr-code {
        order: 1;
    }

    .site-footer__qr-code-image {
        border-radius: 8px;
        display: block;
    }

    .site-footer__social {
        background: var(--color-dark-mid);
        border: 1px solid var(--color-dark-edge);
        border-radius: 10px;
        color: var(--color-dark-text);
        font-family: var(--font-heading);
        font-size: 15px;
        font-weight: 600;
        height: 40px;
        text-decoration: none;
        transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease, opacity var(--duration-fast) ease;
        width: 40px;
    }

    .site-footer__social:active {
        opacity: 0.8;
    }

    .site-footer__social:focus-visible {
        box-shadow: 0 0 0 3px var(--color-accent-20);
        outline: none;
    }

    .site-footer__social:hover {
        border-color: var(--color-accent);
        color: var(--color-surface);
    }

    .site-footer__socials {
        gap: 9px;
    }

    .site-footer__tag {
        color: var(--color-ink-pale);
        font-size: 14.5px;
        line-height: 1.6;
        margin: 0;
    }

    .site-footer__wordmark {
        color: var(--color-surface);
        font-size: clamp(24px, 3vw, 32px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 14px;
    }

    @media (max-width: 768px) {
        .site-footer__bottom {
            align-items: flex-start;
            flex-direction: column;
        }

        .site-footer__inner {
            grid-template-columns: 1fr;
        }

        .site-footer__qr-code {
            order: -1;
        }
    }
</style>
