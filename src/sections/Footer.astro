---
import IconApplePodcasts from '@components/IconApplePodcasts.astro';
import IconDouyin from '@components/IconDouyin.astro';
import IconRedNote from '@components/IconRedNote.astro';
import IconXiaoyuzhou from '@components/IconXiaoyuzhou.astro';
import QrCode from '@components/QrCode.astro';
import { ROUTES, SOCIALS } from '@lib/constants';

const ICONS: Record<string, typeof IconApplePodcasts> = {
    'Apple Podcasts': IconApplePodcasts,
    'Douyin (抖音)': IconDouyin,
    'Xiaohongshu (RedNote)': IconRedNote,
    'Xiaoyuzhou (小宇宙)': IconXiaoyuzhou,
};
---

<footer
    class="site-footer"
    aria-label="Site footer"
>
    <div class="shell site-footer__inner grid items-start">
        <div>
            <h2 class="site-footer__wordmark">InterSub</h2>
            <p class="site-footer__tag" data-i18n="Business English coaching, workshops, and events for Chinese professionals who lead meetings, close deals, and write under pressure. We practise on your real work and give feedback you use the same day. Based in Shanghai.">Business English coaching, workshops, and events for Chinese professionals who lead meetings, close deals, and write under pressure. We practise on your real work and give feedback you use the same day. Based in Shanghai.</p>
        </div>
        <div class="site-footer__column flex flex-col">
            <p class="site-footer__heading" data-i18n="Directory">Directory</p>
            <div class="flex flex-col gap-3">
                {ROUTES.map(route => (
                    <a
                        class="site-footer__link"
                        href={route.href}
                    >
                        <span data-i18n={route.label}>{route.label}</span>
                    </a>
                ))}
                {import.meta.env.DEV && (
                    <a
                        class="site-footer__link"
                        href="/admin"
                    >
                        <span data-i18n="Admin">Admin</span>
                    </a>
                )}
            </div>
        </div>
        <div class="site-footer__column site-footer__connect flex flex-col gap-5">
            <div class="site-footer__qr-code">
                <p class="site-footer__heading" data-i18n="Weixin">Weixin</p>
                <QrCode size={100} />
            </div>
            <div>
                <p class="site-footer__heading" data-i18n="Follow">Follow</p>
                <div class="site-footer__socials flex flex-wrap gap-2">
                    {SOCIALS.map((soc) => {
                        const Icon = ICONS[soc.label];
                        return 'href' in soc
                            ? (
                                    <a
                                        class="site-footer__social site-footer__social--link flex items-center justify-center"
                                        aria-label={soc.label}
                                        href={soc.href}
                                        target="_blank"
                                        title={soc.label}
                                    >
                                        {Icon && <Icon size={22} />}
                                    </a>
                                )
                            : (
                                    <span
                                        class="site-footer__social flex items-center justify-center"
                                        title={soc.label}
                                    >
                                        {Icon && <Icon size={22} />}
                                    </span>
                                );
                    })}
                </div>
            </div>
        </div>
    </div>
    <div class="shell site-footer__bottom select-none">
        <span data-i18n-html="footer-copyright">&copy; 2026 InterSub. All rights reserved.</span>
        <span data-i18n="Founded by Lydia Zhu">Founded by Lydia Zhu</span>
    </div>
</footer>

<style>
    .site-footer {
        background: var(--color-slate);
        color: var(--color-slate-pale);
    }

    .site-footer__bottom {
        align-items: center;
        border-top: 1px solid var(--color-slate-edge);
        color: var(--color-slate-light);
        display: flex;
        font-size: 12px;
        gap: 8px 24px;
        justify-content: space-between;
        padding-block: 28px;
    }

    .site-footer__heading {
        color: var(--color-slate-light);
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        margin: 0 0 16px;
        text-transform: uppercase;
    }

    .site-footer__inner {
        gap: 40px;
        grid-template-columns: 1.6fr 1fr 1.2fr;
        padding-bottom: 40px;
        padding-top: clamp(48px, 6vw, 72px);
    }

    .site-footer__link {
        color: var(--color-slate-text);
        font-size: 16px;
        text-decoration: none;
        transition: color var(--duration-fast) ease, opacity var(--duration-fast) ease;
    }

    .site-footer__link:active {
        opacity: 0.7;
    }

    .site-footer__link:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-footer__link:hover {
        color: var(--color-white);
    }

    .site-footer__qr-code {
        order: 1;
    }

    .site-footer__qr-code-image {
        border-radius: 8px;
        display: block;
    }

    .site-footer__social {
        background: var(--color-slate-mid);
        border: 1px solid var(--color-slate-edge);
        border-radius: 10px;
        color: var(--color-slate-text);
        font-family: var(--font-heading);
        font-size: 16px;
        font-weight: 600;
        height: 40px;
        user-select: none;
        width: 40px;
    }

    .site-footer__social--link {
        text-decoration: none;
        transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease;
    }

    .site-footer__social--link:active {
        opacity: 0.8;
    }

    .site-footer__social--link:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-footer__social--link:hover {
        border-color: var(--color-cobalt);
        color: var(--color-white);
    }

    .site-footer__tag {
        color: var(--color-slate-pale);
        font-size: 16px;
        line-height: 1.6;
        margin: 0;
    }

    .site-footer__wordmark {
        color: var(--color-white);
        font-size: clamp(24px, 3vw, 32px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 14px;
    }

    @media (max-width: 768px) {
        .site-footer__bottom {
            align-items: flex-start;
            flex-direction: column;
        }

        .site-footer__inner {
            grid-template-columns: 1fr;
        }

        .site-footer__qr-code {
            order: -1;
        }
    }
</style>
