---
import IconApplePodcasts from '@components/IconApplePodcasts.astro';
import IconXiaoyuzhou from '@components/IconXiaoyuzhou.astro';
import QrCode from '@components/QrCode.astro';
import logoEn from '@images/logo_en.webp';
import logoZh from '@images/logo_zh.webp';
import { ROUTES } from '@lib/constants';

const ICONS: Record<(typeof SOCIALS)[number]['slug'], typeof IconApplePodcasts> = {
    'apple-podcasts': IconApplePodcasts,
    'xiaoyuzhou': IconXiaoyuzhou,
};

const SOCIALS = [
    { href: 'https://xiaoyuzhoufm.com/podcast/6911ae852e59334c8539c411', label: 'Xiaoyuzhou (小宇宙)', slug: 'xiaoyuzhou' },
    { href: 'https://podcasts.apple.com/cn/podcast/id1856157603', label: 'Apple Podcasts', slug: 'apple-podcasts' },
] as const;

const WECHAT_URL = 'https://u.wechat.com/MIhe6eduSSoNWiw9INP9YEQ?s=2';
---

<footer
    class="site-footer"
    aria-label="Site footer"
    data-i18n-aria="Site footer"
>
    <div class="site-footer__inner shell grid items-start">
        <div>
            <div class="site-footer__brand flex items-center">
                <img class="site-footer__wordmark" alt="InterSub" decoding="async" height="32" lang="en" loading="lazy" src={logoEn.src} />
                <img class="site-footer__wordmark" alt="言际阁" decoding="async" height="32" lang="zh" loading="lazy" src={logoZh.src} />
            </div>
            <p class="site-footer__tag" data-i18n="We are dedicated to enhancing English communication skills for adults and providing solutions tailored to specific workplace and life needs.">We are dedicated to enhancing English communication skills for adults and providing solutions tailored to specific workplace and life needs.</p>
        </div>
        <div class="site-footer__column flex flex-col">
            <p class="site-footer__heading" data-i18n="Directory">Directory</p>
            <div class="flex flex-col gap-3">
                {ROUTES.map(route => (
                    <a
                        class="site-footer__link"
                        href={route.href}
                    >
                        <span data-i18n={route.label}>{route.label}</span>
                    </a>
                ))}
                {import.meta.env.DEV && (
                    <a
                        class="site-footer__link"
                        href="/admin"
                    >
                        Admin
                    </a>
                )}
            </div>
        </div>
        <div class="site-footer__column site-footer__connect flex flex-col">
            <div>
                <p class="site-footer__heading" data-i18n="Follow">Follow</p>
                <div class="site-footer__socials flex flex-wrap gap-2">
                    {SOCIALS.map((social) => {
                        const Icon = ICONS[social.slug];

                        return (
                            <a
                                class="site-footer__social site-footer__social--link flex items-center justify-center"
                                aria-label={social.label}
                                href={social.href}
                                target="_blank"
                                title={social.label}
                            >
                                <Icon size={22} />
                            </a>
                        );
                    })}
                </div>
            </div>
            <div>
                <p class="site-footer__heading" data-i18n="WeChat">WeChat</p>
                <a class="site-footer__qr-link" href={WECHAT_URL} target="_blank">
                    <QrCode size={128} />
                </a>
            </div>
        </div>
    </div>
    <div class="site-footer__bottom shell select-none">
        <span data-i18n-html="footer-copyright">&copy; 2026 InterSub. All rights reserved.</span>
        <span data-i18n="Founded by Lydia Zhu">Founded by Lydia Zhu</span>
    </div>
</footer>

<style>
    .site-footer {
        background: var(--color-slate);
        color: var(--color-slate-pale);
    }

    .site-footer__bottom {
        align-items: center;
        border-top: 1px solid var(--color-slate-edge);
        color: var(--color-slate-light);
        display: flex;
        font-size: 12px;
        gap: 8px 24px;
        justify-content: space-between;
        padding-block: 28px;
    }

    .site-footer__brand {
        gap: 14px;
        margin-bottom: 14px;
    }

    .site-footer__connect {
        gap: 20px;
    }

    .site-footer__heading {
        color: var(--color-slate-light);
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        margin: 0 0 16px;
        text-transform: uppercase;
    }

    .site-footer__inner {
        gap: 40px;
        grid-template-columns: 1.6fr 1fr 1.2fr;
        padding-bottom: 40px;
        padding-top: clamp(48px, calc(40px + 2.5vw), 72px);
    }

    .site-footer__link {
        color: var(--color-slate-text);
        font-size: 16px;
        text-decoration: none;
        transition: color var(--duration-fast) ease, opacity var(--duration-fast) ease;
    }

    .site-footer__link:active {
        opacity: 0.7;
    }

    .site-footer__link:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-footer__link:hover {
        color: var(--color-white);
    }

    .site-footer__qr-link {
        background: var(--color-white);
        border-radius: 10px;
        color: var(--color-slate);
        display: inline-block;
        line-height: 0;
        padding: 16px;
        transition: opacity var(--duration-fast) ease;
    }

    .site-footer__qr-link:active {
        opacity: 0.7;
    }

    .site-footer__qr-link:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-footer__qr-link:hover {
        opacity: 0.85;
    }

    .site-footer__social {
        background: var(--color-slate-mid);
        border: 1px solid var(--color-slate-edge);
        border-radius: 10px;
        color: var(--color-slate-text);
        font-family: var(--font-heading);
        font-size: 16px;
        font-weight: 600;
        height: 40px;
        user-select: none;
        width: 40px;
    }

    .site-footer__social--link {
        text-decoration: none;
        transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease, opacity var(--duration-fast) ease;
    }

    .site-footer__social--link:active {
        opacity: 0.8;
    }

    .site-footer__social--link:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-footer__social--link:hover {
        border-color: var(--color-cobalt);
        color: var(--color-white);
    }

    .site-footer__tag {
        color: var(--color-slate-pale);
        font-size: 16px;
        line-height: 1.6;
        margin: 0;
    }

    .site-footer__wordmark {
        display: block;
        height: 32px;
        width: auto;
    }

    @media (max-width: 768px) {
        .site-footer__bottom {
            align-items: flex-start;
            flex-direction: column;
        }

        .site-footer__connect {
            gap: 40px;
        }

        .site-footer__inner {
            grid-template-columns: 1fr;
        }
    }
</style>
