---
import { getTestimonials } from '@lib/store';

const testimonials = await getTestimonials();
---

<section
    class="section testimonials"
    aria-label="Client testimonials"
    data-i18n-aria="Client testimonials"
    data-testimonials
>
    <div class="testimonials__inner shell">
        <p class="testimonials__eyebrow" data-i18n="From the people in the room" data-scroll>From the people in the room</p>
        <div
            class="testimonials__carousel"
            data-scroll
        >
            {testimonials.map((testimonial, index) => (
                <figure
                    class:list={['testimonials__slide', { 'testimonials__slide--active': index === 0 }]}
                    data-slide={index}
                >
                    <blockquote class="testimonials__quote">&ldquo;<span data-i18n={testimonial.quote}>{testimonial.quote}</span>&rdquo;</blockquote>
                    <figcaption>
                        <span class="testimonials__name">{testimonial.name}</span>
                        <span class="testimonials__role" data-i18n={testimonial.role}>{testimonial.role}</span>
                        <span class="testimonials__industry" data-i18n={testimonial.industry}>{testimonial.industry}</span>
                    </figcaption>
                </figure>
            ))}
        </div>
        <ul
            class="testimonials__dots flex justify-center gap-0"
            data-scroll
        >
            {testimonials.map((_, index) => (
                <li>
                    <button
                        class:list={['testimonials__dot', { 'testimonials__dot--active': index === 0 }]}
                        aria-label={`Show testimonial ${index + 1}`}
                        data-dot={index}
                        type="button"
                    />
                </li>
            ))}
        </ul>
    </div>
</section>

<style>
    .testimonials {
        background: var(--color-slate);
    }

    .testimonials__carousel {
        display: grid;
        margin-bottom: clamp(36px, calc(30.67px + 1.67vw), 52px);
        margin-inline: auto;
        max-width: 800px;
    }

    .testimonials__dot {
        background: transparent;
        border: none;
        display: grid;
        height: 48px;
        padding: 0;
        place-items: center;
        width: 48px;
    }

    .testimonials__dot::before {
        background: var(--color-slate-light);
        border-radius: 99px;
        content: '';
        height: 10px;
        transition: background var(--duration-slow) ease, opacity var(--duration-fast) ease, width var(--duration-slow) ease;
        width: 10px;
    }

    .testimonials__dot:active::before {
        opacity: 0.7;
    }

    .testimonials__dot:focus-visible {
        outline: none;
    }

    .testimonials__dot:focus-visible::before {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
    }

    .testimonials__dot:hover::before {
        background: var(--color-slate-pale);
    }

    .testimonials__dot--active::before {
        background: var(--color-cobalt-bright);
        width: 32px;
    }

    .testimonials__dot--active:hover::before {
        background: var(--color-cobalt-bright);
    }

    .testimonials__eyebrow {
        color: color-mix(in srgb, var(--color-cobalt) 70%, var(--color-white));
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.14em;
        margin: 0 0 44px;
        text-transform: uppercase;
        user-select: none;
    }

    .testimonials__industry {
        color: var(--color-slate-pale);
        display: block;
        font-size: 12px;
    }

    .testimonials__inner {
        text-align: center;
    }

    .testimonials__name {
        color: var(--color-white);
        display: block;
        font-size: 16px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .testimonials__quote {
        color: var(--color-slate-text);
        font-family: var(--font-heading);
        font-size: clamp(24px, calc(21.33px + 0.83vw), 32px);
        font-weight: 500;
        letter-spacing: -0.015em;
        line-height: 1.32;
        margin: 0 0 32px;
        text-wrap: balance;
    }

    .testimonials__role {
        color: var(--color-slate-pale);
        display: block;
        font-size: 16px;
        margin-bottom: 2px;
    }

    .testimonials__slide {
        grid-area: 1 / 1;
        margin: 0;
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--duration-slow) ease;
    }

    .testimonials__slide--active {
        opacity: 1;
        pointer-events: auto;
    }
</style>

<script>
    import { translate } from '@lib/i18n';

    interface Rotator {
        currentIndex: number;
        dots: NodeListOf<HTMLElement>;
        isPaused: boolean;
        slides: NodeListOf<HTMLElement>;
    }

    const ROTATE_INTERVAL = 5_200;

    let controller: AbortController;
    let testimonialInterval: ReturnType<typeof setInterval> | undefined;

    function initTestimonials() {
        if (controller) controller.abort();
        if (testimonialInterval) clearInterval(testimonialInterval);

        controller = new AbortController();

        const section = document.querySelector<HTMLElement>('[data-testimonials]');

        if (!section) return;

        const dots = section.querySelectorAll<HTMLElement>('[data-dot]');
        const slides = section.querySelectorAll<HTMLElement>('[data-slide]');

        if (!slides.length) return;

        const rotator: Rotator = { currentIndex: 0, dots, isPaused: false, slides };

        function handleDotClick(event: Event) {
            if (!(event.currentTarget instanceof HTMLElement)) return;

            showSlide(rotator, Number(event.currentTarget.dataset.dot));
            resetInterval(rotator);
        }

        dots.forEach((dot) => {
            dot.addEventListener('click', handleDotClick, { signal: controller.signal });
        });

        section.addEventListener('mouseenter', () => {
            rotator.isPaused = true;
        }, { signal: controller.signal });

        section.addEventListener('mouseleave', () => {
            rotator.isPaused = false;
        }, { signal: controller.signal });

        section.addEventListener('focusin', () => {
            rotator.isPaused = true;
        }, { signal: controller.signal });

        section.addEventListener('focusout', (event) => {
            if (!(event.relatedTarget instanceof Node) || !section.contains(event.relatedTarget)) rotator.isPaused = false;
        }, { signal: controller.signal });

        labelDots(dots);
        resetInterval(rotator);

        window.addEventListener('lang:change', () => labelDots(dots), { signal: controller.signal });
    }

    function labelDots(dots: NodeListOf<HTMLElement>) {
        dots.forEach((dot, dotIndex) => {
            dot.setAttribute('aria-label', `${translate('Show testimonial')} ${dotIndex + 1}`);
        });
    }

    function resetInterval(rotator: Rotator) {
        if (testimonialInterval) clearInterval(testimonialInterval);
        testimonialInterval = setInterval(() => {
            if (!rotator.isPaused) showSlide(rotator, (rotator.currentIndex + 1) % rotator.slides.length);
        }, ROTATE_INTERVAL);
    }

    function showSlide(rotator: Rotator, index: number) {
        rotator.slides.forEach((slide, slideIndex) => {
            slide.classList.toggle('testimonials__slide--active', slideIndex === index);
        });

        rotator.dots.forEach((dot, dotIndex) => {
            dot.classList.toggle('testimonials__dot--active', dotIndex === index);
        });

        rotator.currentIndex = index;
    }

    document.addEventListener('astro:before-swap', () => {
        if (testimonialInterval) clearInterval(testimonialInterval);
    });

    document.addEventListener('astro:page-load', initTestimonials);
</script>
