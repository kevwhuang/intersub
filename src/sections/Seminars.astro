---
import { formatDate, getDifficultyMeta, getInitials } from '@lib/utils';
import { getSeminars } from '@lib/store';

const seminars = await getSeminars();
const locations = [...new Set(seminars.map(seminar => String(seminar.location)))].sort();
const DIFFICULTIES = ['all', 'Advanced', 'Beginner', 'Intermediate'] as const;
---

<div class="seminars" data-seminars>
    <section class="seminars__hero" aria-labelledby="seminars-title">
        <div class="shell">
            <h1 id="seminars-title" class="seminars__title" data-i18n="Seminars">Seminars</h1>
            <p class="seminars__subtitle" data-i18n-html="seminars-subtitle">Focused intensives in Shanghai, each targeting a specific business English skill. Negotiation, executive presence, written communication, investor pitching, and more. Browse past and upcoming sessions below.</p>
        </div>
    </section>

    <section class="section" aria-label="Seminar catalog">
        <div class="shell">
            <div class="seminars__toolbar">
                <div class="seminars__filters">
                    <div>
                        <p class="seminars__filter-label" data-i18n="Location">Location</p>
                        <div class="flex flex-wrap gap-2">
                            <button
                                class="chip chip--active"
                                data-filter-location="all"
                                type="button"
                            >
                                <span data-i18n="Everywhere">Everywhere</span>
                            </button>
                            {locations.map(loc => (
                                <button
                                    class="chip"
                                    data-filter-location={loc}
                                    type="button"
                                >
                                    <span data-i18n={loc}>{loc}</span>
                                </button>
                            ))}
                        </div>
                    </div>
                    <div>
                        <p class="seminars__filter-label" data-i18n="Level">Level</p>
                        <div class="flex flex-wrap gap-2">
                            {DIFFICULTIES.map(d => (
                                <button
                                    class:list={['chip', { 'chip--active': d === 'all' }]}
                                    data-filter-difficulty={d}
                                    type="button"
                                >
                                    <span data-i18n={d === 'all' ? 'All levels' : d}>{d === 'all' ? 'All levels' : d}</span>
                                </button>
                            ))}
                        </div>
                    </div>
                </div>
                <p class="seminars__count" data-count>
                    {seminars.length} {seminars.length === 1 ? 'seminar' : 'seminars'}
                </p>
            </div>

            <div class="seminars__grid" data-grid>
                {seminars.map((sem) => {
                    const meta = getDifficultyMeta(sem.difficulty);
                    const initials = getInitials(sem.title);
                    return (
                        <a
                            class="seminars__card"
                            data-card
                            data-card-difficulty={sem.difficulty}
                            data-card-location={sem.location}
                            href={`/seminars/${sem.date}`}
                        >
                            <div
                                class="seminars__card-cover"
                                style={`background:${meta.cover};color:${meta.ink}`}
                            >
                                {sem.cover
                                    ? <img class="seminars__card-image" alt="" src={sem.cover} />
                                    : <span class="seminars__card-initials">{initials}</span>}
                            </div>
                            <div class="seminars__card-body">
                                <h2 class="seminars__card-title" data-i18n={sem.title}>{sem.title}</h2>
                                {sem.difficulty && (
                                    <div class="seminars__card-badge">
                                        <span class={`tag tag--${sem.difficulty}`} data-i18n={meta.label}>{meta.label}</span>
                                    </div>
                                )}
                                <div class="seminars__card-details">
                                    <div class="seminars__card-row">
                                        <span class="seminars__card-key" data-i18n="Date">Date</span>
                                        <span class="seminars__card-value" data-i18n-date={sem.date}>{formatDate(sem.date)}</span>
                                    </div>
                                    <div class="seminars__card-row">
                                        <span class="seminars__card-key" data-i18n="Location">Location</span>
                                        <span class="seminars__card-value" data-i18n={sem.location}>{sem.location}</span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>

            <div class="seminars__empty" data-empty style="display:none">
                <h2 class="seminars__empty-title" data-i18n="No seminars match those filters">No seminars match those filters</h2>
                <p class="seminars__empty-text" data-i18n="Try widening your selection. New sessions are added throughout the season.">Try widening your selection. New sessions are added throughout the season.</p>
                <button class="button" data-clear-filters data-i18n="Clear all filters" type="button">Clear all filters</button>
            </div>
        </div>
    </section>
</div>

<style>
    .seminars__card {
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        text-decoration: none;
        transition: border-color var(--duration-fast) ease, box-shadow var(--duration-fast) ease, transform var(--duration-fast) ease;
    }

    .seminars__card:active {
        opacity: 0.95;
        transform: translateY(0);
    }

    .seminars__card:focus-visible {
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px var(--color-accent-20);
        outline: none;
    }

    .seminars__card:hover {
        border-color: var(--color-border-hover);
        box-shadow: 0 12px 32px var(--color-dark-15);
        transform: translateY(-3px);
    }

    .seminars__card-badge {
        margin-bottom: 14px;
    }

    .seminars__card-body {
        display: flex;
        flex: 1;
        flex-direction: column;
        padding: 22px 22px 24px;
    }

    .seminars__card-cover {
        align-items: center;
        border-bottom: 1px solid var(--color-border);
        display: flex;
        height: 150px;
        justify-content: center;
        overflow: hidden;
    }

    .seminars__card-details {
        border-top: 1px solid var(--color-border);
        display: flex;
        flex-direction: column;
        gap: 7px;
        padding-top: 14px;
    }

    .seminars__card-image {
        height: 100%;
        object-fit: cover;
        width: 100%;
    }

    .seminars__card-initials {
        font-family: var(--font-heading);
        font-size: 46px;
        font-weight: 700;
        letter-spacing: -0.02em;
        opacity: 0.32;
    }

    .seminars__card-key {
        color: var(--color-ink-ghost);
        font-size: 13.5px;
    }

    .seminars__card-row {
        display: flex;
        font-family: var(--font-sans);
        font-size: 13.5px;
        gap: 12px;
        justify-content: space-between;
    }

    .seminars__card-title {
        color: var(--color-ink);
        flex: 1;
        font-size: 19px;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.22;
        margin: 0 0 16px;
    }

    .seminars__card-value {
        color: var(--color-ink);
        font-weight: 600;
        text-align: right;
    }

    .seminars__count {
        color: var(--color-ink-ghost);
        font-family: var(--font-mono);
        font-size: 12.5px;
        margin: 0;
        white-space: nowrap;
    }

    .seminars__empty {
        background: var(--color-surface-raised);
        border: 1px dashed var(--color-border-hover);
        border-radius: 16px;
        padding: clamp(48px, 8vw, 88px) 32px;
        text-align: center;
    }

    .seminars__empty-text {
        color: var(--color-ink-muted);
        font-size: 15.5px;
        line-height: 1.6;
        margin: 0 auto 24px;
    }

    .seminars__empty-title {
        color: var(--color-ink);
        font-size: 22px;
        font-weight: 600;
        margin: 0 0 10px;
    }

    .seminars__filter-label {
        color: var(--color-ink-ghost);
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        margin: 0 0 11px;
        text-transform: uppercase;
    }

    .seminars__filters {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .seminars__grid {
        display: grid;
        gap: 22px;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 330px), 1fr));
    }

    .seminars__hero {
        border-bottom: 1px solid var(--color-border);
        padding-bottom: clamp(48px, 7vw, 84px);
        padding-top: calc(var(--header-height) + clamp(48px, 7vw, 84px));
    }

    .seminars__subtitle {
        color: var(--color-ink-muted);
        font-size: clamp(16px, 1.3vw, 18px);
        line-height: 1.6;
        margin: 20px 0 0;
    }

    .seminars__title {
        color: var(--color-ink);
        font-size: clamp(32px, 4.6vw, 54px);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.06;
        margin: 0;
        text-wrap: balance;
    }

    .seminars__toolbar {
        align-items: flex-end;
        border-bottom: 1px solid var(--color-border);
        display: flex;
        flex-wrap: wrap;
        gap: 24px 40px;
        justify-content: space-between;
        margin-bottom: 36px;
        padding-bottom: 28px;
    }
</style>

<script>
    import { translate } from '@lib/i18n';

    const DEFAULT_FILTER = 'all';

    function initSeminarFilters() {
        const root = document.querySelector<HTMLElement>('[data-seminars]');
        if (!root) return;

        let activeDifficulty = DEFAULT_FILTER;
        let activeLocation = DEFAULT_FILTER;

        const cards = root.querySelectorAll<HTMLElement>('[data-card]');
        const countEl = root.querySelector<HTMLElement>('[data-count]');
        const emptyEl = root.querySelector<HTMLElement>('[data-empty]');
        const gridEl = root.querySelector<HTMLElement>('[data-grid]');
        const difficultyButtons = root.querySelectorAll<HTMLButtonElement>('[data-filter-difficulty]');
        const locationButtons = root.querySelectorAll<HTMLButtonElement>('[data-filter-location]');

        function update() {
            let visible = 0;

            cards.forEach((card) => {
                const d = card.dataset.cardDifficulty;
                const l = card.dataset.cardLocation;
                const show =
                    (activeDifficulty === DEFAULT_FILTER || d === activeDifficulty) &&
                    (activeLocation === DEFAULT_FILTER || l === activeLocation);

                card.style.display = show ? '' : 'none';
                if (show) visible++;
            });

            difficultyButtons.forEach((button) => {
                button.classList.toggle('chip--active', button.dataset.filterDifficulty === activeDifficulty);
            });
            locationButtons.forEach((button) => {
                button.classList.toggle('chip--active', button.dataset.filterLocation === activeLocation);
            });

            if (countEl) {
                const unit = translate(visible === 1 ? 'seminar' : 'seminars');
                countEl.textContent = `${visible} ${unit}`;
            }
            if (gridEl) gridEl.style.display = visible ? '' : 'none';
            if (emptyEl) emptyEl.style.display = visible ? 'none' : '';
        }

        difficultyButtons.forEach((button) => {
            button.addEventListener('click', () => {
                activeDifficulty = button.dataset.filterDifficulty || DEFAULT_FILTER;
                update();
            });
        });

        locationButtons.forEach((button) => {
            button.addEventListener('click', () => {
                activeLocation = button.dataset.filterLocation || DEFAULT_FILTER;
                update();
            });
        });

        root.querySelector('[data-clear-filters]')?.addEventListener('click', () => {
            activeDifficulty = DEFAULT_FILTER;
            activeLocation = DEFAULT_FILTER;
            update();
        });

        update();

        window.addEventListener('lang:change', update);
    }

    document.addEventListener('astro:page-load', initSeminarFilters);
</script>
