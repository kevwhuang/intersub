---
import { EMAIL_MAX, MESSAGE_MAX, NAME_MAX, WECHAT_MAX } from '@lib/constants';
---

<section
    id="contact"
    class="contact section"
    aria-labelledby="contact-title"
>
    <div class="contact__ring contact__ring--1" aria-hidden="true" />
    <div class="contact__ring contact__ring--2" aria-hidden="true" />
    <div class="contact__ring contact__ring--3" aria-hidden="true" />
    <div class="contact__ring contact__ring--4" aria-hidden="true" />
    <div class="contact__ring contact__ring--5" aria-hidden="true" />
    <div class="shell contact__inner">
        <div data-scroll>
            <h2 id="contact-title" class="contact__title" data-i18n="Get in touch">Get in touch</h2>
            <p class="contact__intro" data-i18n="Interested in coaching, a workshop, or one of our events? Tell us about your team, the English situations they face, and what you'd like to improve. We'll reply with a tailored recommendation.">Interested in coaching, a workshop, or one of our events? Tell us about your team, the English situations they face, and what you'd like to improve. We'll reply with a tailored recommendation.</p>
        </div>
        <div class="contact__success" hidden>
            <h3 class="contact__success-title" data-i18n="Thank you, message sent.">Thank you, message sent.</h3>
            <p class="contact__success-text" data-i18n="We've received your note and will be in touch at the email you provided. A copy was routed to intersjt@outlook.com.">We've received your note and will be in touch at the email you provided. A copy was routed to intersjt@outlook.com.</p>
            <button class="button button--outline contact__reset" data-i18n="Send another" type="button">Send another</button>
        </div>
        <form class="contact__form flex flex-col gap-5 text-left" data-scroll novalidate>
            <label class="label">
                <span data-i18n="Name">Name</span> <span class="label__required">*</span>
                <input
                    class="input"
                    aria-describedby="error-name"
                    autocomplete="name"
                    data-i18n-placeholder="Your full name"
                    maxlength={NAME_MAX}
                    name="name"
                    placeholder="Your full name"
                    required
                    type="text"
                />
                <p id="error-name" class="contact__error" data-i18n="Please enter your name." hidden>Please enter your name.</p>
            </label>
            <label class="label">
                <span data-i18n="WeChat">WeChat</span> <span class="label__required">*</span>
                <input
                    class="input"
                    aria-describedby="error-wechat"
                    data-i18n-placeholder="Your WeChat ID or phone number"
                    maxlength={WECHAT_MAX}
                    name="wechat"
                    placeholder="Your WeChat ID or phone number"
                    required
                    type="text"
                />
                <p id="error-wechat" class="contact__error" data-i18n="Please enter your WeChat ID or phone number." hidden>Please enter your WeChat ID or phone number.</p>
            </label>
            <label class="label">
                <span data-i18n="Email">Email</span>
                <input
                    class="input"
                    aria-describedby="error-email"
                    autocomplete="email"
                    data-i18n-placeholder="you@company.com"
                    maxlength={EMAIL_MAX}
                    name="email"
                    placeholder="you@company.com"
                    type="email"
                />
                <p id="error-email" class="contact__error" data-i18n="Please enter a valid email." hidden>Please enter a valid email.</p>
            </label>
            <label class="label">
                <span data-i18n="Message">Message</span> <span class="label__required">*</span>
                <textarea
                    class="textarea"
                    aria-describedby="error-message"
                    data-i18n-placeholder="Your message"
                    maxlength={MESSAGE_MAX}
                    name="message"
                    placeholder="Your message"
                    required
                    rows="5"
                />
                <p id="error-message" class="contact__error" data-i18n="Please add a short message." hidden>Please add a short message.</p>
            </label>
            <button class="button contact__submit self-center" data-i18n="Send message" type="submit">Send message</button>
            <p class="contact__error contact__network-error" data-i18n="Something went wrong. Please try again." hidden role="alert">Something went wrong. Please try again.</p>
        </form>
    </div>
</section>

<style>
    .contact {
        border-bottom: 1px solid var(--color-silver);
        overflow: hidden;
        position: relative;
    }

    .contact__error {
        color: var(--color-red);
        font-size: 12px;
        margin: 8px 0 0;
    }

    .contact__inner {
        max-width: 620px;
        position: relative;
        text-align: center;
        z-index: 1;
    }

    .contact__intro {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0 0 clamp(40px, calc(32px + 2.5vw), 64px);
    }

    .contact__reset {
        font-size: 16px;
        padding: 10px 18px;
    }

    .contact__ring {
        border: 1.5px solid var(--color-silver-muted);
        border-radius: 50%;
        pointer-events: none;
        position: absolute;
        z-index: 0;
    }

    .contact__ring--1 {
        height: clamp(280px, calc(246.67px + 10.42vw), 380px);
        right: clamp(-140px, calc(-60px - 6.25vw), -80px);
        top: clamp(-160px, calc(-80px - 6.25vw), -100px);
        width: clamp(280px, calc(246.67px + 10.42vw), 380px);
    }

    .contact__ring--2 {
        height: clamp(200px, calc(173.33px + 8.33vw), 280px);
        right: clamp(-100px, calc(-33.33px - 5.21vw), -50px);
        top: clamp(-110px, calc(-43.33px - 5.21vw), -60px);
        width: clamp(200px, calc(173.33px + 8.33vw), 280px);
    }

    .contact__ring--3 {
        height: clamp(120px, calc(100px + 6.25vw), 180px);
        right: clamp(-60px, calc(-6.67px - 4.17vw), -20px);
        top: clamp(-60px, calc(-6.67px - 4.17vw), -20px);
        width: clamp(120px, calc(100px + 6.25vw), 180px);
    }

    .contact__ring--4 {
        bottom: clamp(-140px, calc(-60px - 6.25vw), -80px);
        height: clamp(240px, calc(213.33px + 8.33vw), 320px);
        left: clamp(-120px, calc(-53.33px - 5.21vw), -70px);
        width: clamp(240px, calc(213.33px + 8.33vw), 320px);
    }

    .contact__ring--5 {
        bottom: clamp(-90px, calc(-36.67px - 4.17vw), -50px);
        height: clamp(160px, calc(140px + 6.25vw), 220px);
        left: clamp(-80px, calc(-26.67px - 4.17vw), -40px);
        width: clamp(160px, calc(140px + 6.25vw), 220px);
    }

    .contact__success {
        background: var(--color-cobalt-10);
        border: 1px solid var(--color-cobalt-20);
        border-radius: 14px;
        padding: 40px;
        text-align: center;
    }

    .contact__success-text {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0 0 20px;
    }

    .contact__success-title {
        color: var(--color-slate);
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 10px;
    }

    .contact__title {
        color: var(--color-slate);
        font-size: clamp(28px, calc(21.33px + 2.08vw), 48px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 16px;
    }

    @media (max-width: 1024px) {
        .contact__ring {
            display: none;
        }
    }
</style>

<script>
    import { EMAIL_PATTERN } from '@lib/constants';
    import { translate } from '@lib/i18n';

    const ERROR_GENERIC = 'Something went wrong. Please try again.';
    const ERROR_RATE_LIMITED = 'Too many requests. Please try again later.';
    const STATUS_RATE_LIMITED = 429;

    let controller: AbortController;

    function initContact() {
        if (controller) controller.abort();
        controller = new AbortController();

        const section = document.querySelector('.contact');

        if (!section) return;

        const form = section.querySelector<HTMLFormElement>('.contact__form');
        const resetButton = section.querySelector<HTMLElement>('.contact__reset');
        const successPanel = section.querySelector<HTMLElement>('.contact__success');

        const submitButton = form?.querySelector<HTMLButtonElement>('.contact__submit');

        if (!form || !resetButton || !submitButton || !successPanel) return;

        const emailError = form.querySelector<HTMLElement>('#error-email');
        const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
        const errors = form.querySelectorAll<HTMLElement>('.contact__error');
        const messageError = form.querySelector<HTMLElement>('#error-message');
        const messageInput = form.querySelector<HTMLTextAreaElement>('textarea[name="message"]');
        const nameError = form.querySelector<HTMLElement>('#error-name');
        const nameInput = form.querySelector<HTMLInputElement>('input[name="name"]');
        const networkError = form.querySelector<HTMLElement>('.contact__network-error');
        const wechatError = form.querySelector<HTMLElement>('#error-wechat');
        const wechatInput = form.querySelector<HTMLInputElement>('input[name="wechat"]');

        const eventTitle = new URLSearchParams(window.location.search).get('event');

        if (eventTitle && messageInput) {
            messageInput.value = `Hi! I'd like to sign up for \u201C${eventTitle}\u201D.\n\n`;
            history.replaceState(history.state, '', window.location.pathname + window.location.hash);
        }

        function clearErrors() {
            errors.forEach(error => error.hidden = true);

            form.querySelectorAll('.input--error, .textarea--error').forEach((element) => {
                element.classList.remove('input--error', 'textarea--error');
            });
        }

        function showNetworkError(key: string) {
            if (!networkError) return;

            networkError.dataset.i18n = key;
            networkError.textContent = translate(key);
            networkError.hidden = false;
        }

        nameInput?.addEventListener('input', clearErrors, { signal: controller.signal });
        wechatInput?.addEventListener('input', clearErrors, { signal: controller.signal });
        emailInput?.addEventListener('input', clearErrors, { signal: controller.signal });
        messageInput?.addEventListener('input', clearErrors, { signal: controller.signal });

        form.addEventListener('submit', async (event) => {
            event.preventDefault();
            clearErrors();

            let isValid = true;

            if (!nameInput?.value.trim()) {
                if (nameError) nameError.hidden = false;
                nameInput?.classList.add('input--error');
                isValid = false;
            }

            if (!wechatInput?.value.trim() || /\s/.test(wechatInput.value.trim())) {
                if (wechatError) wechatError.hidden = false;
                wechatInput?.classList.add('input--error');
                isValid = false;
            }

            if (emailInput?.value.trim() && !EMAIL_PATTERN.test(emailInput.value.trim())) {
                if (emailError) emailError.hidden = false;
                emailInput?.classList.add('input--error');
                isValid = false;
            }

            if (!messageInput?.value.trim()) {
                if (messageError) messageError.hidden = false;
                messageInput?.classList.add('textarea--error');
                isValid = false;
            }

            if (!isValid) return;

            submitButton.disabled = true;

            try {
                const response = await fetch('/api/contact', {
                    body: JSON.stringify({
                        email: emailInput?.value.trim(),
                        message: messageInput?.value.trim(),
                        name: nameInput?.value.trim(),
                        wechat: wechatInput?.value.trim(),
                    }),
                    headers: { 'Content-Type': 'application/json' },
                    method: 'POST',
                });

                if (!response.ok) {
                    showNetworkError(response.status === STATUS_RATE_LIMITED ? ERROR_RATE_LIMITED : ERROR_GENERIC);

                    return;
                }

                form.hidden = true;
                successPanel.hidden = false;
            } catch {
                showNetworkError(ERROR_GENERIC);
            } finally {
                submitButton.disabled = false;
            }
        }, { signal: controller.signal });

        resetButton.addEventListener('click', () => {
            form.reset();
            clearErrors();
            successPanel.hidden = true;
            form.hidden = false;
        }, { signal: controller.signal });
    }

    document.addEventListener('astro:page-load', initContact);
</script>
