---

---

<section
    id="contact"
    class="contact section"
    aria-labelledby="contact-title"
>
    <div class="contact__ring contact__ring--1" aria-hidden="true" />
    <div class="contact__ring contact__ring--2" aria-hidden="true" />
    <div class="contact__ring contact__ring--3" aria-hidden="true" />
    <div class="contact__ring contact__ring--4" aria-hidden="true" />
    <div class="contact__ring contact__ring--5" aria-hidden="true" />
    <div class="shell contact__inner">
        <div data-scroll>
            <h2 id="contact-title" class="contact__title" data-i18n="Get in Touch">Get in Touch</h2>
            <p class="contact__intro" data-i18n="Interested in coaching, a workshop, or attending an event? Tell us about your team and goals. We will respond within two business days with a tailored recommendation.">Interested in coaching, a workshop, or attending an event? Tell us about your team and goals. We will respond within two business days with a tailored recommendation.</p>
        </div>
        <div class="contact__success" hidden>
            <h3 class="contact__success-title" data-i18n-html="contact-success-title">Thank you, message sent.</h3>
            <p class="contact__success-text" data-i18n-html="contact-success-text">We've received your note and will be in touch at the email you provided. A copy was routed to intersjt@outlook.com.</p>
            <button class="button button--outline contact__reset" data-i18n="Send another" type="button">Send another</button>
        </div>
        <form class="contact__form flex flex-col gap-5 text-left" novalidate>
            <label class="label">
                <span data-i18n="Name">Name</span> <span class="label__required">*</span>
                <input
                    class="input"
                    aria-describedby="error-name"
                    autocomplete="name"
                    data-i18n-placeholder="Your full name"
                    maxlength="100"
                    name="name"
                    placeholder="Your full name"
                    required
                    type="text"
                />
                <p class="contact__error" id="error-name" data-i18n="Please enter your name." hidden>Please enter your name.</p>
            </label>
            <label class="label">
                <span data-i18n="Weixin">Weixin</span> <span class="label__required">*</span>
                <input
                    class="input"
                    aria-describedby="error-weixin"
                    data-i18n-placeholder="Your Weixin ID or number"
                    name="weixin"
                    placeholder="Your Weixin ID or number"
                    required
                    type="text"
                />
                <p class="contact__error" id="error-weixin" data-i18n="Please enter your Weixin ID." hidden>Please enter your Weixin ID.</p>
            </label>
            <label class="label">
                <span data-i18n="Email">Email</span>
                <input
                    class="input"
                    autocomplete="email"
                    data-i18n-placeholder="you@company.com"
                    name="email"
                    placeholder="you@company.com"
                    type="email"
                />
            </label>
            <label class="label">
                <span data-i18n="Message">Message</span> <span class="label__required">*</span>
                <textarea
                    class="textarea"
                    aria-describedby="error-message"
                    data-i18n-placeholder="Tell us about your team, the English situations they face, and what you'd like to improve."
                    maxlength="2000"
                    name="message"
                    placeholder="Tell us about your team, the English situations they face, and what you'd like to improve."
                    required
                    rows="5"
                />
                <p class="contact__error" id="error-message" data-i18n="Please add a short message." hidden>Please add a short message.</p>
            </label>
            <button class="button contact__submit self-center" data-i18n="Send message" type="submit">Send message</button>
            <p class="contact__error contact__network-error" hidden>Something went wrong. Please try again.</p>
        </form>
    </div>
</section>

<style>
    .contact {
        border-bottom: 1px solid var(--color-silver);
        overflow: hidden;
        position: relative;
    }

    .contact__error {
        color: var(--color-red);
        font-size: 12px;
        margin: 8px 0 0;
    }

    .contact__inner {
        max-width: 620px;
        position: relative;
        text-align: center;
        z-index: 1;
    }

    .contact__intro {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0 0 clamp(40px, 5vw, 64px);
    }

    .contact__reset {
        font-size: 16px;
        padding: 10px 18px;
    }

    .contact__ring {
        border: 1.5px solid var(--color-silver-muted);
        border-radius: 50%;
        pointer-events: none;
        position: absolute;
        z-index: 0;
    }

    .contact__ring--1 {
        height: clamp(280px, 30vw, 380px);
        right: clamp(-140px, -10vw, -80px);
        top: clamp(-160px, -12vw, -100px);
        width: clamp(280px, 30vw, 380px);
    }

    .contact__ring--2 {
        height: clamp(200px, 22vw, 280px);
        right: clamp(-100px, -7vw, -50px);
        top: clamp(-110px, -8vw, -60px);
        width: clamp(200px, 22vw, 280px);
    }

    .contact__ring--3 {
        height: clamp(120px, 14vw, 180px);
        right: clamp(-60px, -3vw, -20px);
        top: clamp(-60px, -4vw, -20px);
        width: clamp(120px, 14vw, 180px);
    }

    .contact__ring--4 {
        bottom: clamp(-140px, -10vw, -80px);
        height: clamp(240px, 26vw, 320px);
        left: clamp(-120px, -9vw, -70px);
        width: clamp(240px, 26vw, 320px);
    }

    .contact__ring--5 {
        bottom: clamp(-90px, -6vw, -50px);
        height: clamp(160px, 18vw, 220px);
        left: clamp(-80px, -5vw, -40px);
        width: clamp(160px, 18vw, 220px);
    }

    .contact__success {
        background: var(--color-cobalt-10);
        border: 1px solid var(--color-cobalt-20);
        border-radius: 14px;
        padding: 40px;
        text-align: center;
    }

    .contact__success-text {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0 0 20px;
    }

    .contact__success-title {
        color: var(--color-slate);
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 10px;
    }

    .contact__title {
        color: var(--color-slate);
        font-size: clamp(28px, 4vw, 48px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 16px;
    }

    @media (max-width: 1024px) {
        .contact__ring {
            display: none;
        }
    }
</style>

<script>
    let controller: AbortController;

    function initContact() {
        if (controller) controller.abort();
        controller = new AbortController();

        const section = document.querySelector('.contact');
        if (!section) return;

        const form = section.querySelector<HTMLFormElement>('.contact__form');
        const submitButton = form?.querySelector<HTMLButtonElement>('.contact__submit');
        const success = section.querySelector<HTMLElement>('.contact__success');
        const reset = section.querySelector<HTMLElement>('.contact__reset');

        if (!form || !submitButton || !success || !reset) return;

        const nameInput = form.querySelector<HTMLInputElement>('input[name="name"]');
        const weixinInput = form.querySelector<HTMLInputElement>('input[name="weixin"]');
        const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
        const messageInput = form.querySelector<HTMLTextAreaElement>('textarea[name="message"]');
        const errors = form.querySelectorAll<HTMLElement>('.contact__error');
        const networkError = form.querySelector<HTMLElement>('.contact__network-error');

        function clearErrors() {
            errors.forEach(error => error.hidden = true);
            if (networkError) networkError.hidden = true;
            form.querySelectorAll('.input--error, .textarea--error').forEach((element) => {
                element.classList.remove('input--error', 'textarea--error');
            });
        }

        nameInput?.addEventListener('input', clearErrors, { signal: controller.signal });
        weixinInput?.addEventListener('input', clearErrors, { signal: controller.signal });
        emailInput?.addEventListener('input', clearErrors, { signal: controller.signal });
        messageInput?.addEventListener('input', clearErrors, { signal: controller.signal });

        form.addEventListener('submit', async (event) => {
            event.preventDefault();
            clearErrors();

            let valid = true;

            if (!nameInput?.value.trim()) {
                errors[0].hidden = false;
                nameInput?.classList.add('input--error');
                valid = false;
            }

            if (!weixinInput?.value.trim() || /\s/.test(weixinInput.value.trim())) {
                errors[1].hidden = false;
                weixinInput?.classList.add('input--error');
                valid = false;
            }

            if (emailInput?.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value.trim())) {
                errors[2].hidden = false;
                emailInput?.classList.add('input--error');
                valid = false;
            }

            if (!messageInput?.value.trim()) {
                errors[3].hidden = false;
                messageInput?.classList.add('textarea--error');
                valid = false;
            }

            if (!valid) return;

            submitButton.disabled = true;

            try {
                const response = await fetch('/api/contact', {
                    body: JSON.stringify({
                        email: emailInput?.value.trim(),
                        message: messageInput?.value.trim(),
                        name: nameInput?.value.trim(),
                        weixin: weixinInput?.value.trim(),
                    }),
                    headers: { 'Content-Type': 'application/json' },
                    method: 'POST',
                });

                if (!response.ok) throw new Error();

                form.hidden = true;
                success.hidden = false;
            } catch {
                if (networkError) networkError.hidden = false;
            } finally {
                submitButton.disabled = false;
            }
        }, { signal: controller.signal });

        reset.addEventListener('click', () => {
            form.reset();
            clearErrors();
            success.hidden = true;
            form.hidden = false;
        }, { signal: controller.signal });
    }

    document.addEventListener('astro:page-load', initContact);
</script>
