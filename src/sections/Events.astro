---
import { Image } from 'astro:assets';

import { LEVELS, TIMINGS } from '@lib/constants';
import { formatDate, getInitials, getLevelMeta } from '@lib/utils';
import { getCoverImage, resolveCover } from '@lib/images';
import { getEvents } from '@lib/store';

const LEVEL_FILTERS = ['all', ...LEVELS] as const;

const events = await getEvents();

const locations = [...new Set(events.map(entry => entry.location))].sort();

const locationFilters = ['all', ...locations];
---

<section
    class="events__hero"
    aria-labelledby="events-title"
>
    <div class="shell">
        <h1 id="events-title" class="events__title" data-i18n="Events" data-scroll>Events</h1>
        <p class="events__subtitle" data-i18n="Our business English community regularly hosts seminars, hands-on workshops, and group discussions centered on practical workplace communication and industry topics. Through structured English improvement marathons and real-world business projects, we support members at every stage, helping them build their skills through consistent micro-learning, systematic development, and practical application in professional contexts." data-scroll>Our business English community regularly hosts seminars, hands-on workshops, and group discussions centered on practical workplace communication and industry topics. Through structured English improvement marathons and real-world business projects, we support members at every stage, helping them build their skills through consistent micro-learning, systematic development, and practical application in professional contexts.</p>
    </div>
</section>

<section
    class="section"
    aria-label="Event catalog"
    data-events
    data-i18n-aria="Event catalog"
>
    <div class="shell">
        <div class="events__toolbar">
            <div class="events__filters flex flex-col gap-5">
                <div>
                    <p class="events__filter-label" data-i18n="When">When</p>
                    <ul class="flex flex-wrap gap-2">
                        {TIMINGS.map(timing => (
                            <li>
                                <button
                                    class:list={['chip', { 'chip--active': timing.value === 'all' }]}
                                    data-filter-timing={timing.value}
                                    type="button"
                                >
                                    <span data-i18n={timing.label}>{timing.label}</span>
                                </button>
                            </li>
                        ))}
                    </ul>
                </div>
                <div>
                    <p class="events__filter-label" data-i18n="Where">Where</p>
                    <ul class="flex flex-wrap gap-2">
                        {locationFilters.map(location => (
                            <li>
                                <button
                                    class:list={['chip', { 'chip--active': location === 'all' }]}
                                    data-filter-location={location}
                                    type="button"
                                >
                                    <span data-i18n={location === 'all' ? 'Everywhere' : location}>{location === 'all' ? 'Everywhere' : location}</span>
                                </button>
                            </li>
                        ))}
                    </ul>
                </div>
                <div>
                    <p class="events__filter-label" data-i18n="Who">Who</p>
                    <ul class="flex flex-wrap gap-2">
                        {LEVEL_FILTERS.map(level => (
                            <li>
                                <button
                                    class:list={['chip', { 'chip--active': level === 'all' }]}
                                    data-filter-level={level}
                                    type="button"
                                >
                                    <span data-i18n={level === 'all' ? 'Everyone' : level}>{level === 'all' ? 'Everyone' : level}</span>
                                </button>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
            <p class="events__count" aria-atomic="true" aria-live="polite" data-count>
                {events.length} {events.length === 1 ? 'event' : 'events'}
            </p>
        </div>
        <div
            class="events__grid"
            data-grid
            data-scroll
            data-scroll-stagger="0.08"
        >
            {events.map((event) => {
                const coverImage = getCoverImage(event.cover ?? '');
                const initials = getInitials(event.title);
                const meta = getLevelMeta(event.level ?? '');

                return (
                    <a
                        class="events__card"
                        data-card
                        data-card-date={event.date}
                        data-card-level={event.level}
                        data-card-location={event.location}
                        href={`/events/${event.date}`}
                    >
                        <div
                            class="events__card-cover"
                            style={`background:${meta.cover};color:${meta.ink}`}
                        >
                            {event.cover
                                ? coverImage
                                    ? <Image class="events__card-image" alt="" loading="lazy" sizes="(min-width: 768px) 33vw, 100vw" src={coverImage} widths={[480, 800, 1250]} />
                                    : <img class="events__card-image" alt="" decoding="async" loading="lazy" src={resolveCover(event.cover)} />
                                : <span class="events__card-initials" aria-hidden="true">{initials}</span>}
                        </div>
                        <div class="events__card-body">
                            <h2 class="events__card-title">{event.title}</h2>
                            {event.level && (
                                <div class="events__card-badge mb-[14px]">
                                    <span class={`tag tag--${event.level.toLowerCase()}`} data-i18n={event.level}>{event.level}</span>
                                </div>
                            )}
                            <dl class="events__card-details">
                                <div class="events__card-row">
                                    <dt class="events__card-key" data-i18n="Date">Date</dt>
                                    <dd class="events__card-value">
                                        <time data-i18n-date={event.date} datetime={event.date}>{formatDate(event.date)}</time>
                                    </dd>
                                </div>
                                {event.time && (
                                    <div class="events__card-row">
                                        <dt class="events__card-key" data-i18n="Time">Time</dt>
                                        <dd class="events__card-value">{event.time}</dd>
                                    </div>
                                )}
                                <div class="events__card-row">
                                    <dt class="events__card-key" data-i18n="Location">Location</dt>
                                    <dd class="events__card-value" data-i18n={event.location}>{event.location}</dd>
                                </div>
                            </dl>
                        </div>
                    </a>
                );
            })}
        </div>
        <div
            class="events__empty"
            data-empty
            hidden
        >
            <h2 class="events__empty-title" data-i18n="No events match those filters">No events match those filters</h2>
            <p class="events__empty-text" data-i18n="Try widening your selection. New sessions are added regularly.">Try widening your selection. New sessions are added regularly.</p>
            <button class="button" data-clear-filters data-i18n="Clear all filters" type="button">Clear all filters</button>
        </div>
    </div>
</section>

<style>
    .events__card {
        background: var(--color-white);
        border: 1px solid var(--color-silver-strong);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        text-decoration: none;
        transition: border-color var(--duration-fast) ease, box-shadow var(--duration-fast) ease, opacity var(--duration-fast) ease, transform var(--duration-fast) ease;
    }

    .events__card:active {
        opacity: 0.95;
        transform: translateY(0);
    }

    .events__card:focus-visible {
        border-color: var(--color-cobalt);
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .events__card:hover {
        border-color: var(--color-silver-hover);
        box-shadow: 0 12px 32px var(--color-slate-15);
        transform: translateY(-3px);
    }

    .events__card-body {
        display: flex;
        flex: 1;
        flex-direction: column;
        padding: 22px 22px 24px;
    }

    .events__card-cover {
        align-items: center;
        aspect-ratio: 2.5;
        border-bottom: 1px solid var(--color-silver);
        display: flex;
        justify-content: center;
        overflow: hidden;
    }

    .events__card-details {
        border-top: 1px solid var(--color-silver);
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin: 0;
        padding-top: 14px;
    }

    .events__card-image {
        height: 100%;
        object-fit: cover;
        object-position: left top;
        width: 100%;
    }

    .events__card-initials {
        font-family: var(--font-heading);
        font-size: 48px;
        font-weight: 700;
        letter-spacing: -0.02em;
        opacity: 0.32;
    }

    .events__card-key {
        color: var(--color-slate-ghost);
        flex-shrink: 0;
        font-size: 12px;
    }

    .events__card-row {
        display: flex;
        font-size: 12px;
        gap: 12px;
        justify-content: space-between;
    }

    .events__card-title {
        color: var(--color-slate);
        flex: 1;
        font-size: 20px;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.22;
        margin: 0 0 16px;
    }

    .events__card-value {
        color: var(--color-slate);
        font-weight: 600;
        margin: 0;
        text-align: right;
    }

    .events__count {
        color: var(--color-slate-ghost);
        font-family: var(--font-mono);
        font-size: 12px;
        margin: 0;
        white-space: nowrap;
    }

    .events__empty {
        background: var(--color-snow);
        border: 1px dashed var(--color-silver-hover);
        border-radius: 16px;
        padding: clamp(48px, calc(34.67px + 4.17vw), 88px) 32px;
        text-align: center;
    }

    .events__empty-text {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0 auto 24px;
    }

    .events__empty-title {
        color: var(--color-slate);
        font-size: 24px;
        font-weight: 600;
        margin: 0 0 10px;
    }

    .events__filter-label {
        color: var(--color-slate-ghost);
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        margin: 0 0 12px;
        text-transform: uppercase;
        user-select: none;
    }

    .events__grid {
        display: grid;
        gap: 28px;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    }

    .events__hero {
        border-bottom: 1px solid var(--color-silver);
        padding-bottom: clamp(48px, calc(36px + 3.75vw), 84px);
        padding-top: calc(var(--header-height) + clamp(48px, calc(36px + 3.75vw), 84px));
    }

    .events__subtitle {
        color: var(--color-slate-muted);
        font-size: clamp(16px, calc(14.67px + 0.42vw), 20px);
        line-height: 1.6;
        margin: 0;
    }

    .events__title {
        color: var(--color-slate);
        font-size: clamp(32px, calc(24px + 2.5vw), 56px);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.06;
        margin: 0 0 20px;
        text-wrap: balance;
    }

    .events__toolbar {
        align-items: flex-end;
        border-bottom: 1px solid var(--color-silver);
        display: flex;
        flex-wrap: wrap;
        gap: 24px 40px;
        justify-content: space-between;
        margin-bottom: 36px;
        padding-bottom: 28px;
    }
</style>

<script>
    import { getToday } from '@lib/utils';
    import { translate } from '@lib/i18n';

    type FilterKey = 'activeLevel' | 'activeLocation' | 'activeTiming';

    interface FilterState {
        activeLevel: string;
        activeLocation: string;
        activeTiming: string;
        cards: NodeListOf<HTMLElement>;
        countElement: HTMLElement | null;
        emptyElement: HTMLElement | null;
        gridElement: HTMLElement | null;
        levelButtons: NodeListOf<HTMLButtonElement>;
        locationButtons: NodeListOf<HTMLButtonElement>;
        timingButtons: NodeListOf<HTMLButtonElement>;
        today: string;
    }

    const DEFAULT_FILTER = 'all';

    let controller: AbortController;

    function applyFilter(state: FilterState, filterKey: FilterKey, value: string | undefined) {
        state[filterKey] = value || DEFAULT_FILTER;
        update(state);
    }

    function bindFilterGroup(state: FilterState, buttons: NodeListOf<HTMLButtonElement>, filterKey: FilterKey, datasetKey: string) {
        buttons.forEach((button) => {
            button.addEventListener('click', () => applyFilter(state, filterKey, button.dataset[datasetKey]), { signal: controller.signal });
        });
    }

    function clearFilters(state: FilterState) {
        state.activeLevel = DEFAULT_FILTER;
        state.activeLocation = DEFAULT_FILTER;
        state.activeTiming = DEFAULT_FILTER;
        update(state);
    }

    function initEventFilters() {
        if (controller) controller.abort();
        controller = new AbortController();

        const root = document.querySelector<HTMLElement>('[data-events]');

        if (!root) return;

        const state: FilterState = {
            activeLevel: DEFAULT_FILTER,
            activeLocation: DEFAULT_FILTER,
            activeTiming: DEFAULT_FILTER,
            cards: root.querySelectorAll<HTMLElement>('[data-card]'),
            countElement: root.querySelector<HTMLElement>('[data-count]'),
            emptyElement: root.querySelector<HTMLElement>('[data-empty]'),
            gridElement: root.querySelector<HTMLElement>('[data-grid]'),
            levelButtons: root.querySelectorAll<HTMLButtonElement>('[data-filter-level]'),
            locationButtons: root.querySelectorAll<HTMLButtonElement>('[data-filter-location]'),
            timingButtons: root.querySelectorAll<HTMLButtonElement>('[data-filter-timing]'),
            today: getToday(),
        };

        bindFilterGroup(state, state.levelButtons, 'activeLevel', 'filterLevel');
        bindFilterGroup(state, state.locationButtons, 'activeLocation', 'filterLocation');
        bindFilterGroup(state, state.timingButtons, 'activeTiming', 'filterTiming');

        root.querySelector('[data-clear-filters]')?.addEventListener('click', () => clearFilters(state), { signal: controller.signal });

        update(state);

        window.addEventListener('lang:change', () => update(state), { signal: controller.signal });
    }

    function update(state: FilterState) {
        let visibleCount = 0;

        state.cards.forEach((card) => {
            const date = card.dataset.cardDate || '';
            const level = card.dataset.cardLevel;
            const location = card.dataset.cardLocation;

            const matchesTiming = state.activeTiming === DEFAULT_FILTER
                || (state.activeTiming === 'upcoming' && date >= state.today)
                || (state.activeTiming === 'past' && date < state.today);

            const shouldShow = matchesTiming
                && (state.activeLevel === DEFAULT_FILTER || level === state.activeLevel)
                && (state.activeLocation === DEFAULT_FILTER || location === state.activeLocation);

            card.style.display = shouldShow ? '' : 'none';

            if (shouldShow) visibleCount++;
        });

        state.levelButtons.forEach((button) => {
            button.classList.toggle('chip--active', button.dataset.filterLevel === state.activeLevel);
        });

        state.locationButtons.forEach((button) => {
            button.classList.toggle('chip--active', button.dataset.filterLocation === state.activeLocation);
        });

        state.timingButtons.forEach((button) => {
            button.classList.toggle('chip--active', button.dataset.filterTiming === state.activeTiming);
        });

        if (state.countElement) {
            const isChinese = document.documentElement.lang === 'zh';
            const unit = translate(visibleCount === 1 ? 'event' : 'events');

            state.countElement.textContent = isChinese ? `${visibleCount}${unit}` : `${visibleCount} ${unit}`;
        }

        if (state.gridElement) state.gridElement.style.display = visibleCount ? '' : 'none';
        if (state.emptyElement) state.emptyElement.hidden = visibleCount > 0;
    }

    document.addEventListener('astro:page-load', initEventFilters);
</script>
