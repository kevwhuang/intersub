---
import { Image } from 'astro:assets';

import logoEn from '@images/logo_en.webp';
import logoZh from '@images/logo_zh.webp';
import { ROUTES } from '@lib/constants';
---

<header class="site-header fixed">
    <div class="site-header__inner shell flex items-center justify-between">
        <a
            class="site-header__brand flex items-center no-underline select-none"
            aria-label="InterSub Home"
            data-i18n-aria="InterSub Home"
            href="/"
        >
            <Image class="site-header__wordmark" alt="InterSub" densities={[1, 2]} height={24} lang="en" quality="max" src={logoEn} />
            <Image class="site-header__wordmark" alt="言际阁" densities={[1, 2]} height={24} lang="zh" quality="max" src={logoZh} />
        </a>
        <nav
            class="site-nav flex items-center"
            aria-label="Primary"
            data-i18n-aria="Primary"
        >
            <div id="site-nav-menu" class="site-nav__menu flex items-center" data-nav-menu>
                {ROUTES.map(route => (
                    <a
                        class="site-nav__link"
                        href={route.href}
                    >
                        <span data-i18n={route.label}>{route.label}</span>
                    </a>
                ))}
            </div>
            <button
                class="site-nav__language"
                aria-label="Switch language"
                data-i18n-aria="Switch language"
                data-lang-toggle
                type="button"
            >
                中文
            </button>
            <button
                class="site-nav__toggle items-center justify-center"
                aria-controls="site-nav-menu"
                aria-expanded="false"
                aria-label="Toggle navigation"
                data-i18n-aria="Toggle navigation"
                data-nav-toggle
                type="button"
            >
                <span class="site-nav__toggle-bar" aria-hidden="true" />
            </button>
        </nav>
    </div>
</header>

<style>
    .site-header {
        backdrop-filter: saturate(180%) blur(16px);
        background: var(--color-white-95);
        border-bottom: 1px solid var(--color-silver);
        height: var(--header-height);
        left: 0;
        right: 0;
        top: 0;
        z-index: 50;
    }

    .site-header__brand {
        flex: none;
        gap: 12px;
        transition: opacity var(--duration-fast) ease;
    }

    .site-header__brand:active {
        opacity: 0.7;
    }

    .site-header__brand:focus-visible {
        border-radius: 4px;
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-header__brand:hover {
        opacity: 0.85;
    }

    .site-header__inner {
        height: 100%;
    }

    .site-header__wordmark {
        display: block;
        height: clamp(20px, calc(18.67px + 0.42vw), 24px);
        width: auto;
    }

    .site-nav {
        gap: 14px;
    }

    .site-nav__language {
        background: none;
        border: 1px solid var(--color-silver-muted);
        border-radius: 7px;
        color: var(--color-slate-faint);
        font-family: var(--font-sans);
        font-size: 12px;
        font-weight: 600;
        min-width: 44px;
        padding: 6px;
        position: relative;
        text-align: center;
        transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease, opacity var(--duration-fast) ease;
    }

    .site-nav__language:active {
        opacity: 0.8;
    }

    .site-nav__language:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-nav__language:hover {
        border-color: var(--color-slate-ghost);
        color: var(--color-slate);
    }

    .site-nav__language::after {
        content: '';
        inset: -9px -3px;
        position: absolute;
    }

    .site-nav__link {
        border-radius: 9px;
        color: var(--color-slate-faint);
        font-size: 16px;
        font-weight: 600;
        padding: 8px 14px;
        text-decoration: none;
        transition: background var(--duration-fast) ease, color var(--duration-fast) ease, opacity var(--duration-fast) ease;
    }

    .site-nav__link:active {
        opacity: 0.8;
    }

    .site-nav__link:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-nav__link:hover {
        background: var(--color-snow);
        color: var(--color-slate);
    }

    .site-nav__link--active {
        background: var(--color-cobalt);
        color: var(--color-white);
    }

    .site-nav__link--active:hover {
        background: var(--color-cobalt-dark);
        color: var(--color-white);
    }

    .site-nav__menu {
        gap: 14px;
    }

    .site-nav__toggle {
        background: none;
        border: 1px solid var(--color-silver-muted);
        border-radius: 7px;
        color: var(--color-slate-faint);
        display: none;
        height: 30px;
        position: relative;
        transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease, opacity var(--duration-fast) ease;
        width: 36px;
    }

    .site-nav__toggle:active {
        opacity: 0.8;
    }

    .site-nav__toggle:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .site-nav__toggle:hover {
        border-color: var(--color-slate-ghost);
        color: var(--color-slate);
    }

    .site-nav__toggle::after {
        content: '';
        inset: -10px -7px;
        position: absolute;
    }

    .site-nav__toggle-bar {
        background: currentColor;
        box-shadow: 0 -5px 0 currentColor, 0 5px 0 currentColor;
        display: block;
        height: 1.6px;
        width: 14px;
    }

    @media (max-width: 768px) {
        .site-header:has(.site-nav__menu--open) {
            backdrop-filter: none;
            background: var(--color-white);
        }

        .site-header::after {
            background: var(--color-midnight-30);
            content: '';
            inset: var(--header-height) 0 0;
            opacity: 0;
            position: fixed;
            transition: opacity var(--duration-fast) ease, visibility 0s ease var(--duration-fast);
            visibility: hidden;
            z-index: -1;
        }

        .site-header:has(.site-nav__menu--open)::after {
            opacity: 1;
            transition: opacity var(--duration-fast) ease;
            visibility: visible;
        }

        .site-nav__link {
            padding: 12px 14px;
        }

        .site-nav__menu {
            align-items: stretch;
            background: var(--color-white);
            border-bottom: 1px solid var(--color-silver);
            box-shadow: 0 16px 32px var(--color-slate-10);
            flex-direction: column;
            gap: 4px;
            left: 0;
            opacity: 0;
            padding: 12px var(--shell-pad) 16px;
            position: fixed;
            right: 0;
            top: var(--header-height);
            transition: opacity var(--duration-fast) ease, visibility 0s ease var(--duration-fast);
            visibility: hidden;
        }

        .site-nav__menu--instant {
            transition: none;
        }

        .site-nav__menu--open {
            opacity: 1;
            transition: opacity var(--duration-fast) ease;
            visibility: visible;
        }

        .site-nav__toggle {
            display: flex;
        }
    }
</style>

<script>
    import { applyLanguage, toggleLanguage } from '@lib/i18n';

    const MOBILE_QUERY = '(max-width: 768px)';

    let controller: AbortController;

    function applyPublicLanguage() {
        if (window.location.pathname.startsWith('/admin')) return;

        applyLanguage();
    }

    function initNavbar() {
        if (controller) controller.abort();
        controller = new AbortController();

        const currentPath = window.location.pathname.replace(/\/$/, '') || '/';
        const menu = document.querySelector<HTMLElement>('[data-nav-menu]');
        const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');

        function closeMenu(shouldRestoreFocus = false) {
            menu?.classList.remove('site-nav__menu--open');
            toggle?.setAttribute('aria-expanded', 'false');

            if (shouldRestoreFocus) toggle?.focus();
        }

        function openMenu() {
            menu?.classList.add('site-nav__menu--open');
            toggle?.setAttribute('aria-expanded', 'true');
            requestAnimationFrame(() => menu?.querySelector<HTMLElement>('a')?.focus());
        }

        document.querySelectorAll('.site-nav__link').forEach((link) => {
            const href = link.getAttribute('href')?.replace(/\/$/, '') || '/';

            const isActive = href === currentPath;

            link.classList.toggle('site-nav__link--active', isActive);

            if (isActive) {
                link.setAttribute('aria-current', 'page');
            } else {
                link.removeAttribute('aria-current');
            }

            link.addEventListener('click', () => closeMenu(), { signal: controller.signal });
        });

        toggle?.addEventListener('click', () => {
            if (menu?.classList.contains('site-nav__menu--open')) {
                closeMenu();
            } else {
                openMenu();
            }
        }, { signal: controller.signal });

        document.addEventListener('keydown', (event) => {
            if (!menu?.classList.contains('site-nav__menu--open')) return;

            if (event.key === 'Escape') {
                closeMenu(true);

                return;
            }

            if (event.key !== 'Tab') return;

            const header = menu.closest('.site-header');

            if (!header) return;

            const focusables = Array.from(header.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'));

            if (!focusables.length) return;

            const first = focusables[0];
            const last = focusables[focusables.length - 1];
            const active = document.activeElement;

            if (event.shiftKey && (active === first || !header.contains(active))) {
                event.preventDefault();
                last.focus();
            } else if (!event.shiftKey && (active === last || !header.contains(active))) {
                event.preventDefault();
                first.focus();
            }
        }, { signal: controller.signal });

        document.addEventListener('mousedown', (event) => {
            if (!menu?.classList.contains('site-nav__menu--open')) return;
            if (!(event.target instanceof Element)) return;

            if (!event.target.closest('.site-header') || event.clientY >= menu.getBoundingClientRect().bottom) {
                closeMenu();
            }
        }, { signal: controller.signal });

        window.matchMedia(MOBILE_QUERY).addEventListener('change', (event) => {
            if (!event.matches) {
                closeMenu();

                return;
            }

            menu?.classList.add('site-nav__menu--instant');
            requestAnimationFrame(() => requestAnimationFrame(() => menu?.classList.remove('site-nav__menu--instant')));
        }, { signal: controller.signal });

        document.querySelector('[data-lang-toggle]')?.addEventListener('click', toggleLanguage, { signal: controller.signal });
    }

    document.addEventListener('astro:page-load', applyPublicLanguage);
    document.addEventListener('astro:page-load', initNavbar);
</script>
