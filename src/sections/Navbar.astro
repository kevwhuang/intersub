---
import { ROUTES } from '@lib/utils';
---

<header class="site-header fixed">
    <div class="site-header__inner flex items-center justify-between">
        <a
            class="site-header__brand flex items-center no-underline select-none"
            aria-label="InterSub Home"
            href="/"
        >
            <span class="site-header__mark" aria-hidden="true" />
            <span class="site-header__wordmark">InterSub</span>
        </a>
        <nav
            class="site-nav flex items-center"
            aria-label="Primary"
        >
            {ROUTES.map(route => (
                <a
                    class="site-nav__link"
                    href={route.href}
                >
                    <span data-i18n={route.label}>{route.label}</span>
                </a>
            ))}
            <button
                class="site-nav__lang"
                aria-label="Switch language"
                data-lang-toggle
                type="button"
            >
                中文
            </button>
        </nav>
    </div>
</header>

<style>
    .site-header {
        backdrop-filter: saturate(180%) blur(16px);
        background: rgba(255, 255, 255, 0.94);
        border-bottom: 1px solid var(--color-border);
        height: var(--header-height);
        left: 0;
        right: 0;
        top: 0;
        z-index: 50;
        -webkit-backdrop-filter: saturate(180%) blur(16px);
    }

    .site-header__brand {
        gap: 9px;
    }

    .site-header__inner {
        height: 100%;
        margin: 0 auto;
        max-width: var(--shell-max);
        padding: 0 var(--shell-pad);
    }

    .site-header__mark {
        background: var(--color-accent);
        border-radius: 6px;
        display: inline-block;
        height: 22px;
        width: 22px;
    }

    .site-header__wordmark {
        color: var(--color-ink);
        font-family: var(--font-heading);
        font-size: 21px;
        font-weight: 700;
        letter-spacing: -0.02em;
    }

    .site-nav {
        gap: 14px;
    }

    .site-nav__lang {
        background: none;
        border: 1px solid var(--color-border-muted);
        border-radius: 7px;
        color: var(--color-ink-faint);
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 600;
        margin-left: 6px;
        min-width: 44px;
        padding: 6px 0;
        text-align: center;
        transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease;
    }

    .site-nav__lang:hover {
        border-color: var(--color-ink-ghost);
        color: var(--color-ink);
    }

    .site-nav__link {
        border-radius: 9px;
        color: var(--color-ink-faint);
        font-family: var(--font-sans);
        font-size: 15px;
        font-weight: 600;
        padding: 9px 14px;
        text-decoration: none;
        transition: background var(--duration-fast) ease, color var(--duration-fast) ease;
    }

    .site-nav__link:hover {
        background: var(--color-surface-raised);
        color: var(--color-ink);
    }

    .site-nav__link[aria-current='page'] {
        background: var(--color-surface-raised);
        color: var(--color-ink);
    }
</style>

<script>
    import { toggleLanguage } from '@lib/i18n';

    function initNavbar() {
        const currentPath = window.location.pathname.replace(/\/$/, '') || '/';

        document.querySelectorAll('.site-nav__link').forEach(link => {
            const href = link.getAttribute('href')?.replace(/\/$/, '') || '/';

            if (href === currentPath) {
                link.setAttribute('aria-current', 'page');
            } else {
                link.removeAttribute('aria-current');
            }
        });

        document.querySelector('[data-lang-toggle]')?.addEventListener('click', toggleLanguage);
    }

    document.addEventListener('astro:page-load', initNavbar);
</script>
