---
const SOLUTIONS = [
    {
        description: 'Private, focused coaching for adults who need to perform in English in real scenarios: calls, presentations, online and offline meetings, job interviews, and more.',
        details: [
            { label: 'Format', value: 'Private 1:1' },
            { label: 'Details', value: '120 min/week' },
            { label: 'Best for', value: 'Adults with clear needs' },
        ],
        title: '1:1 Coaching',
    },
    {
        description: 'Cohort training built around your team\'s actual communication: the meetings they run and the partners they interact with.',
        details: [
            { label: 'Format', value: 'On-site or remote' },
            { label: 'Details', value: '6\u201314/cohort \u00b7 60\u2013120 min/week' },
            { label: 'Best for', value: 'Functional teams' },
        ],
        title: 'Team Workshops & Course Sessions',
    },
    {
        description: 'Exploring communication, leadership, business thinking, and cross-cultural collaboration through workshops, seminars, and community events.',
        details: [
            { label: 'Format', value: 'Small to medium groups' },
            { label: 'Details', value: 'Beginner to Advanced' },
            { label: 'Best for', value: 'People interested in related topics' },
        ],
        title: 'Co-Created Events',
    },
] as const;
---

<section
    class="solutions section"
    aria-labelledby="solutions-title"
>
    <div class="shell">
        <div class="solutions__header" data-scroll>
            <h2 id="solutions-title" class="solutions__title" data-i18n="Solutions">Solutions</h2>
            <p class="solutions__intro" data-i18n="Three formats, each built around your real situations: the meetings you run, the clients you email, the rooms you need to win.">Three formats, each built around your real situations: the meetings you run, the clients you email, the rooms you need to win.</p>
        </div>
        <div class="solutions__list flex flex-col gap-[22px]" data-scroll data-scroll-stagger="0.12">
            {SOLUTIONS.map(solution => (
                <article class="solutions__card">
                    <div class="solutions__card-main flex flex-col">
                        <div>
                            <h3 class="solutions__card-title" data-i18n={solution.title}>{solution.title}</h3>
                            <p class="solutions__card-description" data-i18n={solution.description}>{solution.description}</p>
                        </div>
                    </div>
                    <dl class="solutions__details">
                        {solution.details.map(detail => (
                            <div class="solutions__detail">
                                <dt class="solutions__detail-key" data-i18n={detail.label}>{detail.label}</dt>
                                <dd class="solutions__detail-value" data-i18n={detail.value}>{detail.value}</dd>
                            </div>
                        ))}
                    </dl>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .solutions {
        background: var(--color-snow);
        border-bottom: 1px solid var(--color-silver);
    }

    .solutions__card {
        align-items: start;
        background: var(--color-white);
        border: 1px solid var(--color-silver-strong);
        border-radius: 18px;
        display: grid;
        gap: clamp(24px, calc(13.33px + 3.33vw), 56px);
        grid-template-columns: 1.1fr 1fr;
        padding: clamp(28px, calc(22.67px + 1.67vw), 44px);
        transition: border-color var(--duration-fast) ease, box-shadow var(--duration-fast) ease, transform var(--duration-fast) ease;
    }

    .solutions__card:hover {
        border-color: var(--color-silver-hover);
        box-shadow: 0 10px 30px var(--color-slate-05);
        transform: translateY(-2px);
    }

    .solutions__card-description {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0;
    }

    .solutions__card-title {
        font-size: clamp(20px, calc(18.67px + 0.42vw), 24px);
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.2;
        margin: 0 0 12px;
    }

    .solutions__detail {
        border-bottom: 1px solid var(--color-silver);
        display: flex;
        font-size: 16px;
        gap: 16px;
        justify-content: space-between;
        padding-bottom: 12px;
    }

    .solutions__detail-key {
        color: var(--color-slate-ghost);
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.04em;
        padding-top: 2px;
        text-transform: uppercase;
    }

    .solutions__detail-value {
        color: var(--color-slate);
        font-weight: 600;
        margin: 0;
        text-align: right;
    }

    .solutions__details {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin: 0;
        padding: 0;
    }

    .solutions__header {
        margin-bottom: clamp(40px, calc(32px + 2.5vw), 64px);
        max-width: 640px;
    }

    .solutions__intro {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0;
    }

    .solutions__title {
        font-size: clamp(28px, calc(21.33px + 2.08vw), 48px);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.08;
        margin: 0 0 18px;
        text-wrap: balance;
    }

    @media (max-width: 768px) {
        .solutions__card {
            grid-template-columns: 1fr;
        }

        .solutions__header {
            text-align: center;
        }
    }
</style>
