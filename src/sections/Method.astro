---
import MethodCurve from '@components/MethodCurve.astro';

const METHOD_BLOCKS = [
    {
        detail: '1:1 coaching, team workshops, and focused events. Every engagement starts from your real work.',
        label: 'What we do',
        statement: 'Customized training based on real scenarios and skill gaps',
        step: '1',
    },
    {
        detail: 'Practice on your real scenarios: actual emails, meeting agendas, deal calls. Activation-based drills, not textbook repetition. No theory. Just results.',
        label: 'How we work',
        statement: 'Six-step closed-loop from diagnosis to results',
        step: '2',
    },
    {
        detail: 'Those who command authority in Mandarin but lose it in English. Also, social strivers and overseas travelers.',
        label: 'Who we serve',
        statement: 'For adult plateau learners, focusing on instant response and fluency',
        step: '3',
    },
    {
        detail: 'Emails that persuade. Calls that close. What you practice today, you use tomorrow.',
        label: 'What changes',
        statement: 'Thinking in English, speaking on instinct',
        step: '4',
    },
] as const;
---

<section
    class="method section"
    aria-label="Our method"
    data-i18n-aria="Our method"
>
    <div class="method__inner shell">
        <MethodCurve />
        {METHOD_BLOCKS.map((block, index) => (
            <div
                class:list={['method__block', { 'method__block--indent': index % 2 === 1 }]}
                data-scroll
            >
                <div class="method__label">
                    <span class="method__number">{block.step}</span>
                    <p class="method__tag" data-i18n={block.label}>{block.label}</p>
                </div>
                <div class="method__text">
                    <h2 class="method__statement" data-i18n={block.statement}>{block.statement}</h2>
                    <p class="method__detail" data-i18n={block.detail}>{block.detail}</p>
                </div>
            </div>
        ))}
    </div>
</section>

<style>
    .method {
        border-bottom: 1px solid var(--color-silver);
        overflow: hidden;
        position: relative;
    }

    .method__block {
        align-items: center;
        display: grid;
        gap: clamp(20px, calc(5.33px + 4.58vw), 64px);
        grid-template-columns: 0.72fr 1.28fr;
        position: relative;
    }

    .method__block--indent {
        padding-left: clamp(0px, calc(-60px + 18.75vw), 180px);
    }

    .method__detail {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.65;
        margin: 0;
        text-wrap: pretty;
    }

    .method__inner {
        display: flex;
        flex-direction: column;
        gap: clamp(44px, calc(29.33px + 4.58vw), 88px);
        position: relative;
    }

    .method__label {
        position: relative;
        text-align: center;
    }

    .method__number {
        color: var(--color-cobalt-85);
        display: block;
        font-family: var(--font-heading);
        font-size: clamp(40px, calc(24px + 5vw), 88px);
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 0.85;
        margin-bottom: 16px;
        user-select: none;
    }

    .method__statement {
        font-size: clamp(20px, calc(16px + 1.25vw), 32px);
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.2;
        margin: 0 0 18px;
        text-wrap: balance;
    }

    .method__tag {
        color: var(--color-slate-ghost);
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        user-select: none;
    }

    @media (max-width: 768px) {
        .method__block {
            grid-template-columns: 1fr;
        }

        .method__block--indent {
            padding-left: 0;
        }

        .method__label {
            align-items: baseline;
            display: flex;
            gap: 12px;
            text-align: left;
        }

        .method__number {
            color: var(--color-cobalt);
            font-size: 16px;
            line-height: 1;
            margin-bottom: 0;
        }

        .method__tag {
            font-size: 16px;
        }

        .method__text {
            width: 100%;
        }
    }
</style>
