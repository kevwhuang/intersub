---
const METHOD_BLOCKS = [
    {
        detail: '1:1 coaching, team workshops, and focused events. Every engagement starts from your real work.',
        label: 'What we do',
        statement: 'Training built on the situations you actually face.',
        step: '1',
    },
    {
        detail: 'Not grammar drills. Specific, honest feedback on your actual calls, emails, and presentations.',
        label: 'How we work',
        statement: 'We practise on your real work and give feedback you use the same day.',
        step: '2',
    },
    {
        detail: 'Directors, founders, procurement leads who already command authority in Mandarin and need it in English.',
        label: 'Who we serve',
        statement: 'Chinese professionals where unclear English costs deals and credibility.',
        step: '3',
    },
    {
        detail: 'Sharper emails within days, more confident calls within weeks, fewer clarifications, faster decisions.',
        label: 'What changes',
        statement: 'Not someday fluency. This week\'s meeting, run with authority.',
        step: '4',
    },
] as const;
---

<section class="method" aria-label="Our method" data-i18n-aria="Our method">
    <div class="shell method__inner">
        <svg class="method__curve" aria-hidden="true" preserveAspectRatio="none" viewBox="0 0 300 1000">
            <path class="method__curve-path" d="M 30 60 C 30 170, 200 170, 200 280 S 30 390, 30 500 S 200 610, 200 720 S 30 830, 30 960" />
            <circle class="method__curve-dot" cx="30" cy="60" r="4" />
            <circle class="method__curve-dot" cx="200" cy="280" r="4" />
            <circle class="method__curve-dot" cx="30" cy="500" r="4" />
            <circle class="method__curve-dot" cx="200" cy="720" r="4" />
        </svg>
        {METHOD_BLOCKS.map((block, index) => (
            <div class:list={['method__block', { 'method__block--indent': index % 2 === 1 }]} data-scroll>
                <div class="method__label">
                    <span class="method__number">{block.step}</span>
                    <p class="method__tag" data-i18n={block.label}>{block.label}</p>
                </div>
                <div class="method__text">
                    <h2 class="method__statement" data-i18n={block.statement}>{block.statement}</h2>
                    <p class="method__detail" data-i18n={block.detail}>{block.detail}</p>
                </div>
            </div>
        ))}
    </div>
</section>

<style>
    .method {
        border-bottom: 1px solid var(--color-silver);
        overflow: hidden;
        position: relative;
    }

    .method__block {
        align-items: start;
        display: grid;
        gap: clamp(20px, calc(5.33px + 4.58vw), 64px);
        grid-template-columns: 0.72fr 1.28fr;
        position: relative;
    }

    .method__block--indent {
        padding-left: clamp(0px, calc(-60px + 18.75vw), 180px);
    }

    .method__curve {
        height: 100%;
        left: 0;
        pointer-events: none;
        position: absolute;
        top: 0;
        width: clamp(100px, calc(53.33px + 14.58vw), 240px);
    }

    .method__curve-dot {
        fill: color-mix(in srgb, var(--color-cobalt) 40%, var(--color-silver-hover));
    }

    .method__curve-path {
        fill: none;
        opacity: 0.7;
        stroke: color-mix(in srgb, var(--color-cobalt) 25%, var(--color-silver-hover));
        stroke-linecap: round;
        stroke-width: 1.5;
    }

    .method__detail {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.65;
        margin: 0;
        text-wrap: pretty;
    }

    .method__inner {
        display: flex;
        flex-direction: column;
        gap: clamp(44px, calc(29.33px + 4.58vw), 88px);
        padding-block: clamp(64px, calc(45.33px + 5.83vw), 120px);
        position: relative;
    }

    .method__label {
        position: relative;
        text-align: center;
    }

    .method__number {
        color: color-mix(in srgb, var(--color-cobalt) 40%, var(--color-white));
        display: block;
        font-family: var(--font-heading);
        font-size: clamp(40px, calc(24px + 5vw), 88px);
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 0.85;
        margin-bottom: 16px;
        user-select: none;
    }

    .method__statement {
        font-size: clamp(20px, calc(16px + 1.25vw), 32px);
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.2;
        margin: 0 0 18px;
        text-wrap: balance;
    }

    .method__tag {
        color: var(--color-slate-ghost);
        font-family: var(--font-mono);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        user-select: none;
    }

    @media (max-width: 768px) {
        .method__block {
            grid-template-columns: 1fr;
        }

        .method__block--indent {
            padding-left: 0;
        }

        .method__curve {
            display: none;
        }

        .method__label {
            align-items: baseline;
            display: flex;
            gap: 12px;
            text-align: left;
        }

        .method__number {
            line-height: 1;
            margin-bottom: 0;
        }

        .method__tag {
            font-size: 16px;
        }

        .method__text {
            width: 100%;
        }
    }
</style>
