---
import { getOutcomes } from '@lib/store';

const outcomes = await getOutcomes();
---

<section
    class="outcomes"
    aria-labelledby="outcomes-title"
>
    <div class="shell">
        <div class="outcomes__header" data-scroll>
            <h2 id="outcomes-title" class="outcomes__title" data-i18n="Outcomes">Outcomes</h2>
            <p class="outcomes__intro" data-i18n="Real case studies from teams we have coached. Measurable shifts in confidence, speed, and clarity within weeks of engagement.">Real case studies from teams we have coached. Measurable shifts in confidence, speed, and clarity within weeks of engagement.</p>
        </div>
        <div class="outcomes__grid">
            {outcomes.map(outcome => (
                <article class="outcomes__card" data-scroll>
                    <h3 class="outcomes__card-title" data-i18n={outcome.title}>{outcome.title}</h3>
                    <p class="outcomes__card-summary" data-i18n={outcome.summary}>{outcome.summary}</p>
                    <ul class="outcomes__points">
                        {outcome.points.map(point => (
                            <li class="outcomes__point" data-i18n={point}>{point}</li>
                        ))}
                    </ul>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .outcomes {
        border-bottom: 1px solid var(--color-border);
        padding: clamp(64px, 9vw, 120px) 0;
    }

    .outcomes__card {
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: 14px;
        border-top: 3px solid var(--color-accent);
        display: flex;
        flex-direction: column;
        padding: 28px;
        transition: background var(--duration-fast) ease, border-color var(--duration-fast) ease, box-shadow var(--duration-fast) ease, transform var(--duration-fast) ease;
    }

    .outcomes__card:nth-child(3n+2) {
        border-top-color: var(--color-success);
    }

    .outcomes__card:nth-child(3n+3) {
        border-top-color: var(--color-warn);
    }

    .outcomes__card:active {
        opacity: 0.95;
        transform: translateY(0);
    }

    .outcomes__card:focus-visible {
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px var(--color-accent-20);
        outline: none;
    }

    .outcomes__card:hover {
        background: var(--color-surface-raised);
        border-color: color-mix(in srgb, var(--color-accent) 40%, var(--color-border-hover));
        box-shadow: 0 14px 36px var(--color-dark-10);
        transform: translateY(-4px);
    }

    .outcomes__card-summary {
        color: var(--color-ink-muted);
        font-size: 14.5px;
        line-height: 1.55;
        margin: 0 0 18px;
    }

    .outcomes__card-title {
        font-size: 18px;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.2;
        margin: 0 0 10px;
    }

    .outcomes__grid {
        display: grid;
        gap: 22px;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    }

    .outcomes__header {
        margin-bottom: clamp(40px, 5vw, 64px);
        max-width: 640px;
    }

    .outcomes__intro {
        color: var(--color-ink-muted);
        font-size: clamp(16px, 1.3vw, 18px);
        line-height: 1.6;
        margin: 0;
    }

    .outcomes__point {
        color: var(--color-ink-faint);
        display: flex;
        font-size: 13.5px;
        gap: 9px;
        line-height: 1.45;
    }

    .outcomes__point::before {
        color: var(--color-accent);
        content: '·';
        flex: none;
        font-weight: 700;
    }

    .outcomes__points {
        border-top: 1px solid var(--color-border);
        display: flex;
        flex-direction: column;
        gap: 8px;
        list-style: none;
        margin: auto 0 0;
        padding: 16px 0 0;
    }

    .outcomes__title {
        font-size: clamp(28px, 4vw, 46px);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.08;
        margin: 0 0 18px;
        text-wrap: balance;
    }

    @media (max-width: 768px) {
        .outcomes__header {
            text-align: center;
        }
    }
</style>
