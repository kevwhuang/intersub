---
import { getOutcomes } from '@lib/store';

const outcomes = await getOutcomes();
---

<section
    class="outcomes section"
    aria-labelledby="outcomes-title"
>
    <div class="shell">
        <div class="outcomes__header" data-scroll>
            <h2 id="outcomes-title" class="outcomes__title" data-i18n="Outcomes">Outcomes</h2>
            <p class="outcomes__intro" data-i18n="Real case studies from teams we have coached. Measurable shifts in confidence, speed, and clarity within weeks of engagement.">Real case studies from teams we have coached. Measurable shifts in confidence, speed, and clarity within weeks of engagement.</p>
        </div>
        <div class="outcomes__grid" data-scroll data-scroll-stagger="0.1">
            {outcomes.map(outcome => (
                <article class="outcomes__card">
                    <h3 class="outcomes__card-title" data-i18n={outcome.title}>{outcome.title}</h3>
                    <p class="outcomes__card-summary" data-i18n={outcome.summary}>{outcome.summary}</p>
                    <ul class="outcomes__points">
                        {outcome.points.map(point => (
                            <li class="outcomes__point" data-i18n={point}>{point}</li>
                        ))}
                    </ul>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .outcomes {
        border-bottom: 1px solid var(--color-silver);
    }

    .outcomes__card {
        background: var(--color-white);
        border: 1px solid var(--color-silver-strong);
        border-radius: 14px;
        border-top: 3px solid var(--color-cobalt);
        display: flex;
        flex-direction: column;
        padding: 28px;
        transition: background var(--duration-fast) ease, border-color var(--duration-fast) ease, box-shadow var(--duration-fast) ease, transform var(--duration-fast) ease;
    }

    .outcomes__card:hover {
        background: var(--color-snow);
        border-color: color-mix(in srgb, var(--color-cobalt) 40%, var(--color-silver-hover));
        box-shadow: 0 14px 36px var(--color-slate-10);
        transform: translateY(-4px);
    }

    .outcomes__card:nth-child(3n+2) {
        border-top-color: var(--color-teal);
    }

    .outcomes__card:nth-child(3n+3) {
        border-top-color: var(--color-amber);
    }

    .outcomes__card-summary {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.55;
        margin: 0 0 18px;
    }

    .outcomes__card-title {
        font-size: 20px;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.2;
        margin: 0 0 10px;
    }

    .outcomes__grid {
        display: grid;
        gap: 22px;
        grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    }

    .outcomes__header {
        margin-bottom: clamp(40px, calc(32px + 2.5vw), 64px);
        max-width: 640px;
    }

    .outcomes__intro {
        color: var(--color-slate-muted);
        font-size: 16px;
        line-height: 1.6;
        margin: 0;
    }

    .outcomes__point {
        color: var(--color-slate-faint);
        display: flex;
        font-size: 12px;
        gap: 8px;
        line-height: 1.45;
    }

    .outcomes__point::before {
        color: var(--color-cobalt);
        content: '\00B7';
        flex: none;
        font-weight: 700;
    }

    .outcomes__points {
        border-top: 1px solid var(--color-silver);
        display: flex;
        flex-direction: column;
        gap: 8px;
        list-style: none;
        margin: auto 0 0;
        padding: 16px 0 0;
    }

    .outcomes__title {
        font-size: clamp(28px, calc(21.33px + 2.08vw), 48px);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.08;
        margin: 0 0 18px;
        text-wrap: balance;
    }

    @media (max-width: 768px) {
        .outcomes__header {
            text-align: center;
        }
    }
</style>
