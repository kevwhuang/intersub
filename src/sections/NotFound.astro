---

---

<section
    class="not-found"
    aria-label="Page not found"
>
    <div class="shell not-found__inner">
        <p class="not-found__code" aria-hidden="true">404</p>
        <h1 class="not-found__title" data-i18n="This page doesn't exist">This page doesn't exist</h1>
        <p class="not-found__text" data-i18n="The link you followed may be outdated, or the page may have been moved. Here are some places to start instead.">The link you followed may be outdated, or the page may have been moved. Here are some places to start instead.</p>
        <div class="not-found__actions">
            <a class="button" href="/"><span data-i18n="Home">Home</span></a>
            <a class="button button--outline" href="/seminars"><span data-i18n="Seminars">Seminars</span></a>
        </div>
    </div>
</section>

<style>
    .not-found {
        align-items: center;
        display: flex;
        justify-content: center;
        min-height: calc(100vh - var(--header-height));
        padding-bottom: clamp(48px, 8vw, 100px);
        padding-top: calc(var(--header-height) + clamp(48px, 8vw, 100px));
    }

    .not-found__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .not-found__code {
        color: color-mix(in srgb, var(--color-accent) 18%, var(--color-surface));
        font-family: var(--font-heading);
        font-size: clamp(120px, 20vw, 240px);
        font-weight: 700;
        letter-spacing: -0.05em;
        line-height: 0.8;
        margin: 0 0 clamp(24px, 4vw, 40px);
    }

    .not-found__inner {
        max-width: 600px;
    }

    .not-found__text {
        color: var(--color-ink-muted);
        font-size: clamp(16px, 1.3vw, 18px);
        line-height: 1.6;
        margin: 0 0 32px;
    }

    .not-found__title {
        font-size: clamp(24px, 3.5vw, 38px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
    }
</style>
