---
import Footer from '@sections/Footer.astro';
import Layout from '@/Layout.astro';
import Navbar from '@sections/Navbar.astro';
import { formatDate, getLevelMeta, getInitials } from '@lib/utils';
import { getEvents } from '@lib/store';

type ContentBlock = { content: string; type: 'h' | 'li' | 'p' };

function parseEventContent(md: string) {
    const blocks: ContentBlock[] = [];

    for (const line of (md || '').split('\n')) {
        const trimmed = line.trim();

        if (!trimmed) continue;
        if (trimmed.startsWith('## ')) blocks.push({ content: trimmed.slice(3), type: 'h' });
        else if (trimmed.startsWith('- ')) blocks.push({ content: trimmed.slice(2), type: 'li' });
        else blocks.push({ content: trimmed, type: 'p' });
    }

    return blocks;
}

export const prerender = false;

const { slug } = Astro.params;
const events = await getEvents();

const found = events.find(entry => String(entry.date) === slug);

if (!found) return Astro.redirect('/404');

const cover = String(found.cover || '');
const date = String(found.date);
const level = String(found.level || '');
const location = String(found.location);
const title = String(found.title);

const meta = getLevelMeta(level);
const initials = getInitials(title);
const rawBlocks = parseEventContent(String(found.content));
const grouped: Array<{ items: string[]; type: ContentBlock['type'] }> = [];
for (const block of rawBlocks) {
    if (block.type === 'li' && grouped.length && grouped[grouped.length - 1].type === 'li') {
        grouped[grouped.length - 1].items.push(block.content);
    } else {
        grouped.push({ items: [block.content], type: block.type });
    }
}
---

<Layout
    description={`${title}. ${meta.label ? `${meta.label} level. ` : ''}Business English event in ${location} for Chinese professionals. Coaching and practice on real workplace communication.`}
    title={`${title} | InterSub`}
>
    <Navbar />
    <main class="flex flex-col flex-1">
        <article class="event-detail">
            <div class="shell">
                <a class="event-detail__back" href="/events">
                    <span>&larr;</span>
                    <span data-i18n="All events">All events</span>
                </a>
                <h1 class="event-detail__title" data-i18n={title} data-scroll>{title}</h1>
                <dl class="event-detail__meta" data-scroll>
                    <div>
                        <dt class="event-detail__meta-label" data-i18n="Date">Date</dt>
                        <dd class="event-detail__meta-value">
                            <time data-i18n-date={date} datetime={date}>{formatDate(date)}</time>
                        </dd>
                    </div>
                    <div>
                        <dt class="event-detail__meta-label" data-i18n="Location">Location</dt>
                        <dd class="event-detail__meta-value" data-i18n={location}>{location}</dd>
                    </div>
                    {level && (
                        <div>
                            <dt class="event-detail__meta-label" data-i18n="Who">Who</dt>
                            <dd class="event-detail__meta-value" data-i18n={meta.label}>{meta.label}</dd>
                        </div>
                    )}
                </dl>
                <div
                    class="event-detail__cover"
                    data-scroll
                    style={`background:${meta.cover};color:${meta.ink}`}
                >
                    {cover
                        ? <img class="event-detail__cover-image" alt="" src={cover} />
                        : <span class="event-detail__cover-initials">{initials}</span>}
                </div>
                <div class="prose event-detail__content" data-scroll>
                    {grouped.map((group) => {
                        if (group.type === 'h') return <h2>{group.items[0]}</h2>;
                        if (group.type === 'li') return <ul>{group.items.map(item => <li>{item}</li>)}</ul>;
                        return <p>{group.items[0]}</p>;
                    })}
                </div>
                <div class="event-detail__actions">
                    <a class="button" href="/#contact"><span data-i18n="Register">Register</span></a>
                    <a class="button button--outline" href="/events"><span data-i18n="Back to all">Back to all</span></a>
                </div>
            </div>
        </article>
    </main>
    <Footer />
</Layout>

<style>
    .event-detail {
        padding-bottom: clamp(64px, 9vw, 120px);
        padding-top: calc(var(--header-height) + clamp(28px, 4vw, 44px));
    }

    .event-detail__actions {
        align-items: center;
        border-top: 1px solid var(--color-silver);
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        padding-top: 36px;
    }

    .event-detail__back {
        align-items: center;
        color: var(--color-slate-faint);
        display: inline-flex;
        font-size: 16px;
        font-weight: 600;
        gap: 8px;
        margin-bottom: 28px;
        text-decoration: none;
        transition: color var(--duration-fast) ease, opacity var(--duration-fast) ease;
    }

    .event-detail__back:active {
        opacity: 0.7;
    }

    .event-detail__back:focus-visible {
        box-shadow: 0 0 0 3px var(--color-cobalt-20);
        outline: none;
    }

    .event-detail__back:hover {
        color: var(--color-cobalt);
    }

    .event-detail__content {
        margin-bottom: 48px;
    }

    .event-detail__cover {
        align-items: center;
        border: 1px solid var(--color-silver);
        border-radius: 16px;
        display: flex;
        aspect-ratio: 2.5;
        justify-content: center;
        margin-bottom: 44px;
        overflow: hidden;
    }

    .event-detail__cover-image {
        height: 100%;
        object-fit: cover;
        width: 100%;
    }

    .event-detail__cover-initials {
        font-family: var(--font-heading);
        font-size: clamp(60px, 12vw, 120px);
        font-weight: 700;
        letter-spacing: -0.03em;
        opacity: 0.26;
    }

    .event-detail__meta {
        border-bottom: 1px solid var(--color-silver);
        border-top: 1px solid var(--color-silver);
        display: flex;
        flex-wrap: wrap;
        gap: 14px 40px;
        margin-bottom: 36px;
        padding: 22px 0;
    }

    .event-detail__meta-label {
        color: var(--color-slate-ghost);
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        margin: 0 0 6px;
        text-transform: uppercase;
    }

    .event-detail__meta-value {
        color: var(--color-slate);
        font-size: 16px;
        font-weight: 600;
        margin: 0;
    }

    .event-detail__title {
        color: var(--color-slate);
        font-size: clamp(32px, 4.4vw, 48px);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.06;
        margin: 0 0 28px;
        text-wrap: balance;
    }
</style>
