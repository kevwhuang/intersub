---
import EventDetail from '@sections/EventDetail.astro';
import Footer from '@sections/Footer.astro';
import Layout from '@/Layout.astro';
import Navbar from '@sections/Navbar.astro';
import { getEvents } from '@lib/store';

const events = await getEvents();
const { slug } = Astro.params;

const event = events.find(entry => entry.date === slug);

if (!event) return Astro.rewrite('/404');

const { level = '', title } = event;

export const prerender = false;
---

<Layout
    description={`${title}: a business English event with live practice and coaching in workplace communication. ${level ? `${level} level.` : 'Open to all levels.'}`}
    title={`${title} \u2014 InterSub`}
>
    <Navbar />
    <main class="flex flex-col flex-1">
        <EventDetail event={event} />
    </main>
    <Footer />
</Layout>
