---
import Footer from '@sections/Footer.astro';
import Layout from '@/Layout.astro';
import Navbar from '@sections/Navbar.astro';

export const prerender = false;
---

<Layout
    description="An unexpected error occurred. Please try again or return to the homepage."
    title="Server Error &mdash; InterSub"
>
    <Navbar />
    <main class="flex flex-1 flex-col">
        <section class="error-page">
            <div class="shell">
                <p class="error-page__code" aria-hidden="true">500</p>
                <h1 class="error-page__title" data-i18n="Something went wrong">Something went wrong</h1>
                <p class="error-page__text" data-i18n="An unexpected error occurred. Try refreshing the page or returning home.">An unexpected error occurred. Try refreshing the page or returning home.</p>
                <div class="error-page__actions">
                    <button class="button" data-i18n="Refresh" onclick="window.location.reload()">Refresh</button>
                    <a class="button button--outline" href="/"><span data-i18n="Home">Home</span></a>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .error-page {
        align-items: center;
        display: flex;
        flex: 1;
        justify-content: center;
        padding-bottom: clamp(64px, 9vw, 110px);
        padding-top: calc(var(--header-height) + clamp(48px, 7vw, 84px));
    }

    .error-page__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .error-page__code {
        color: var(--color-accent-10);
        font-family: var(--font-heading);
        font-size: clamp(120px, 20vw, 240px);
        font-weight: 700;
        letter-spacing: -0.05em;
        line-height: 0.8;
        margin: 0 0 16px;
    }

    .error-page__text {
        color: var(--color-ink-muted);
        font-size: clamp(16px, 1.3vw, 18px);
        line-height: 1.6;
        margin: 0 0 32px;
    }

    .error-page__title {
        font-size: clamp(24px, 3.5vw, 38px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
    }
</style>
