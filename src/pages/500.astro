---
import Footer from '@sections/Footer.astro';
import Layout from '@/Layout.astro';
import Navbar from '@sections/Navbar.astro';

export const prerender = false;
---

<Layout
    description="An unexpected error occurred on InterSub. Please try again or return to the homepage to browse business English coaching and events in Shanghai."
    title="Server Error &mdash; InterSub"
>
    <Navbar />
    <main class="flex flex-col flex-1">
        <section class="server-error" aria-labelledby="server-error-title">
            <div class="shell server-error__inner max-w-[620px] text-center">
                <p class="server-error__code" aria-hidden="true">500</p>
                <h1 id="server-error-title" class="server-error__title" data-i18n="Something went wrong">Something went wrong</h1>
                <p class="server-error__text" data-i18n="An unexpected error occurred. Try refreshing the page or returning home.">An unexpected error occurred. Try refreshing the page or returning home.</p>
                <div class="server-error__actions flex justify-center">
                    <a class="button" href="/"><span data-i18n="Go home">Go home</span></a>
                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>

<style>
    .server-error {
        align-items: center;
        display: flex;
        justify-content: center;
        min-height: calc(100vh - var(--header-height));
        padding-bottom: clamp(48px, 8vw, 100px);
        padding-top: calc(var(--header-height) + clamp(48px, 8vw, 100px));
    }

    .server-error__code {
        color: color-mix(in srgb, var(--color-cobalt) 18%, var(--color-white));
        font-family: var(--font-heading);
        font-size: clamp(120px, 20vw, 240px);
        font-weight: 700;
        letter-spacing: -0.05em;
        line-height: 0.8;
        margin: 0 0 clamp(24px, 4vw, 40px);
        user-select: none;
    }

    .server-error__text {
        color: var(--color-slate-muted);
        font-size: clamp(16px, 1.3vw, 20px);
        line-height: 1.6;
        margin: 0 0 32px;
    }

    .server-error__title {
        font-size: clamp(24px, 3.5vw, 40px);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 12px;
    }
</style>
