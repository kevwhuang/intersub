---
import ErrorServer from '@sections/ErrorServer.astro';
import Footer from '@sections/Footer.astro';
import Layout from '@/Layout.astro';
import Navbar from '@sections/Navbar.astro';

export const prerender = false;
---

<Layout
    description="An unexpected error occurred on InterSub. Please try again or return to the homepage to browse business English coaching and events."
    title={'Server Error \u2014 InterSub'}
>
    <Navbar />
    <main class="flex flex-col flex-1">
        <ErrorServer />
    </main>
    <Footer />
</Layout>
