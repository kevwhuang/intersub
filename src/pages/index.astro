---
import Contact from '@sections/Contact.astro';
import Footer from '@sections/Footer.astro';
import Hero from '@sections/Hero.astro';
import Layout from '@/Layout.astro';
import Method from '@sections/Method.astro';
import Navbar from '@sections/Navbar.astro';
import Outcomes from '@sections/Outcomes.astro';
import Solutions from '@sections/Solutions.astro';
import Testimonials from '@sections/Testimonials.astro';

export const prerender = false;
---

<Layout
    description="Business English training for Chinese professionals. Private coaching, team workshops, and seminars in Shanghai. Founded by Lydia Zhu."
    title="InterSub"
>
    <Navbar />
    <main class="flex flex-1 flex-col">
        <Hero />
        <Method />
        <Solutions />
        <Outcomes />
        <Testimonials />
        <Contact />
    </main>
    <Footer />
</Layout>
